<!-- views/afterlogin/layouts/dashboard.ejs -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - JobHub
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f0f2f5;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        .sidebar-wrapper {
            width: 280px;
            min-height: 100vh;
            background: #1a1a2e;
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            overflow-y: auto;
            z-index: 1000;
            transition: all 0.3s ease;
        }

        .sidebar-wrapper::-webkit-scrollbar {
            width: 5px;
        }

        .sidebar-wrapper::-webkit-scrollbar-track {
            background: #2d3748;
        }

        .sidebar-wrapper::-webkit-scrollbar-thumb {
            background: #4a5568;
            border-radius: 10px;
        }

        .main-content-wrapper {
            margin-left: 280px;
            flex: 1;
            padding: 20px 30px;
            min-height: 100vh;
            transition: all 0.3s ease;
        }

        .sidebar {
            padding: 20px 15px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .sidebar .nav-link {
            padding: 10px 15px;
            border-radius: 8px;
            transition: all 0.3s ease;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            display: block;
        }

        .sidebar .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white !important;
        }

        .sidebar .nav-link.active {
            background: rgba(13, 110, 253, 0.3);
            color: white !important;
        }

        .sidebar .nav-link .badge {
            float: right;
            margin-top: 2px;
        }

        .profile-image .rounded-circle {
            border: 3px solid rgba(255, 255, 255, 0.2);
        }

        @media (max-width: 992px) {
            .sidebar-wrapper {
                width: 240px;
            }

            .main-content-wrapper {
                margin-left: 240px;
                padding: 15px 20px;
            }
        }

        @media (max-width: 768px) {
            .sidebar-wrapper {
                width: 100%;
                min-height: auto;
                position: relative;
                height: auto;
            }

            .main-content-wrapper {
                margin-left: 0;
                padding: 15px;
            }

            .dashboard-container {
                flex-direction: column;
            }
        }

        @media (max-width: 576px) {
            .main-content-wrapper {
                padding: 10px;
            }
        }
    </style>
</head>

<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <div class="sidebar-wrapper">
            <div class="sidebar bg-dark text-white">
                <!-- Profile Section -->
                <div class="text-center mb-4 pb-3 border-bottom border-secondary">
                    <div class="profile-image mb-3">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center mx-auto"
                            style="width: 80px; height: 80px;">
                            <i class="fa fa-user fa-3x text-white"></i>
                        </div>
                    </div>
                    <h6 class="mb-1">
                        <%= userName || 'John Doe' %>
                    </h6>
                    <small class="text-muted">
                        <%= userEmail || 'john@example.com' %>
                    </small>
                    <div class="mt-2">
                        <span class="badge bg-<%= userRole === 'employer' ? 'primary' : 'info' %>">
                            <i class="fa <%= userRole === 'employer' ? 'fa-briefcase' : 'fa-user' %> me-1"></i>
                            <%= userRole==='employer' ? 'Employer' : 'Job Seeker' %>
                        </span>
                    </div>
                </div>

                <!-- Navigation Menu -->
                <nav class="nav flex-column">
                    <a href="/dashboard"
                        class="nav-link text-white <%= activePage === 'dashboard' ? 'active' : '' %> mb-2">
                        <i class="fa fa-dashboard me-2"></i> Dashboard
                    </a>

                    <% if (userRole==='employer' ) { %>
                        <a href="/creat-new-job"
                            class="nav-link <%= activePage === 'create-job' ? 'active' : '' %> mb-2">
                            <i class="fa fa-plus-circle me-2"></i> Post New Job
                        </a>
                        <a href="/my-jobs" class="nav-link <%= activePage === 'jobs' ? 'active' : '' %> mb-2">
                            <i class="fa fa-briefcase me-2"></i> My Jobs
                            <% if (totalJobs> 0) { %>
                                <span class="badge bg-primary">
                                    <%= totalJobs %>
                                </span>
                                <% } %>
                        </a>
                        <% } else { %>
                            <a href="/applications"
                                class="nav-link <%= activePage === 'my-applications' ? 'active' : '' %> mb-2">
                                <i class="fa fa-file-text me-2"></i> My Applications
                                <% if (myApplicationsCount> 0) { %>
                                    <span class="badge bg-primary">
                                        <%= myApplicationsCount %>
                                    </span>
                                    <% } %>
                            </a>
                            <% } %>

                                <a href="/settings"
                                    class="nav-link <%= activePage === 'settings' ? 'active' : '' %> mb-2">
                                    <i class="fa fa-cog me-2"></i> Settings
                                </a>

                                <hr class="bg-secondary">
                                <a href="/logout" class="nav-link text-danger mb-2">
                                    <i class="fa fa-sign-out me-2"></i> Logout
                                </a>
                </nav>

                <!-- Stats Section -->
                <div class="mt-auto pt-4 border-top border-secondary">
                    <div class="small text-muted mb-2">Quick Stats</div>

                    <% if (userRole==='employer' ) { %>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Total Jobs:</span>
                            <strong class="text-white">
                                <%= totalJobs || 0 %>
                            </strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Active Jobs:</span>
                            <strong class="text-success">
                                <%= activeJobs || 0 %>
                            </strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Applications:</span>
                            <strong class="text-info">
                                <%= totalApplications || 0 %>
                            </strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Total Views:</span>
                            <strong class="text-warning">
                                <%= totalViews || 0 %>
                            </strong>
                        </div>
                        <% } else { %>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Applications:</span>
                                <strong class="text-info">
                                    <%= myApplicationsCount || 0 %>
                                </strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Shortlisted:</span>
                                <strong class="text-success">
                                    <%= shortlistedCount || 0 %>
                                </strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Saved Jobs:</span>
                                <strong class="text-warning">
                                    <%= savedJobsCount || 0 %>
                                </strong>
                            </div>
                            <% } %>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content-wrapper">
            <%- include('../' + body) %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>