<!-- views/afterlogin/partials/sidebar.ejs -->
<div class="sidebar bg-dark text-white p-3">
    <!-- Profile Section -->
    <div class="text-center mb-4 pb-3 border-bottom border-secondary">
        <div class="profile-image mb-3">
            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center mx-auto"
                style="width: 80px; height: 80px;">
                <i class="fa fa-user fa-3x text-white"></i>
            </div>
        </div>
        <h6 class="mb-1">
            <%= userName || 'John Doe' %>
        </h6>
        <small class="text-muted">
            <%= userEmail || 'john@example.com' %>
        </small>
        <div class="mt-2">
            <span class="badge bg-<%= userRole === 'employer' ? 'primary' : 'info' %>">
                <i class="fa <%= userRole === 'employer' ? 'fa-briefcase' : 'fa-user' %> me-1"></i>
                <%= userRole==='employer' ? 'Employer' : 'Job Seeker' %>
            </span>
        </div>
    </div>

    <!-- Navigation Menu -->
    <nav class="nav flex-column">
        <a href="/dashboard" class="nav-link text-white <%= activePage === 'dashboard' ? 'active' : '' %> mb-2">
            <i class="fa fa-dashboard me-2"></i> Dashboard
        </a>

        <% if (userRole==='employer' ) { %>
            <a href="/creat-new-job"
                class="nav-link text-white-50 <%= activePage === 'create-job' ? 'active' : '' %> mb-2">
                <i class="fa fa-plus-circle me-2"></i> Post New Job
            </a>
            <a href="/my-jobs" class="nav-link text-white-50 <%= activePage === 'jobs' ? 'active' : '' %> mb-2">
                <i class="fa fa-briefcase me-2"></i> My Jobs
                <% if (totalJobs> 0) { %>
                    <span class="badge bg-primary float-end">
                        <%= totalJobs %>
                    </span>
                    <% } %>
            </a>
            <a href="/applications"
                class="nav-link text-white-50 <%= activePage === 'applications' ? 'active' : '' %> mb-2">
                <i class="fa fa-file-text me-2"></i> Applications
                <% if (pendingApplications> 0) { %>
                    <span class="badge bg-danger float-end">
                        <%= pendingApplications %>
                    </span>
                    <% } %>
            </a>
            <a href="/short-list"
                class="nav-link text-white-50 <%= activePage === 'shortlisted' ? 'active' : '' %> mb-2">
                <i class="fa fa-star me-2"></i> Shortlisted
                <% if (shortlistedCount> 0) { %>
                    <span class="badge bg-success float-end">
                        <%= shortlistedCount %>
                    </span>
                    <% } %>
            </a>
            <% } else { %>
                <a href="/applications"
                    class="nav-link text-white-50 <%= activePage === 'applications' ? 'active' : '' %> mb-2">
                    <i class="fa fa-file-text me-2"></i> My Applications
                    <% if (myApplicationsCount> 0) { %>
                        <span class="badge bg-primary float-end">
                            <%= myApplicationsCount %>
                        </span>
                        <% } %>
                </a>
                <a href="/job-alerts"
                    class="nav-link text-white-50 <%= activePage === 'job-alerts' ? 'active' : '' %> mb-2">
                    <i class="fa fa-bell me-2"></i> Job Alerts
                </a>
                <a href="/profile" class="nav-link text-white-50 <%= activePage === 'profile' ? 'active' : '' %> mb-2">
                    <i class="fa fa-user me-2"></i> My Profile
                </a>
                <% } %>

                    <a href="/settings"
                        class="nav-link text-white-50 <%= activePage === 'settings' ? 'active' : '' %> mb-2">
                        <i class="fa fa-cog me-2"></i> Settings
                    </a>

                    <hr class="bg-secondary">
                    <a href="/logout" class="nav-link text-danger mb-2">
                        <i class="fa fa-sign-out me-2"></i> Logout
                    </a>
    </nav>

    <!-- Stats Section -->
    <div class="mt-auto pt-4 border-top border-secondary">
        <div class="small text-muted mb-2">Quick Stats</div>

        <% if (userRole==='employer' ) { %>
            <div class="d-flex justify-content-between mb-2">
                <span>Total Jobs:</span>
                <strong class="text-white">
                    <%= totalJobs || 0 %>
                </strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span>Active Jobs:</span>
                <strong class="text-success">
                    <%= activeJobs || 0 %>
                </strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span>Applications:</span>
                <strong class="text-info">
                    <%= totalApplications || 0 %>
                </strong>
            </div>
            <div class="d-flex justify-content-between">
                <span>Total Views:</span>
                <strong class="text-warning">
                    <%= totalViews || 0 %>
                </strong>
            </div>
            <% } else { %>
                <div class="d-flex justify-content-between mb-2">
                    <span>Applications:</span>
                    <strong class="text-info">
                        <%= myApplicationsCount || 0 %>
                    </strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Shortlisted:</span>
                    <strong class="text-success">
                        <%= shortlistedCount || 0 %>
                    </strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Saved Jobs:</span>
                    <strong class="text-warning">
                        <%= savedJobsCount || 0 %>
                    </strong>
                </div>
                <% } %>
    </div>
</div>

<style>
    .sidebar {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .sidebar .nav-link {
        padding: 10px 15px;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .sidebar .nav-link:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white !important;
    }

    .sidebar .nav-link.active {
        background: rgba(13, 110, 253, 0.3);
        color: white !important;
    }

    .sidebar .nav-link.text-white-50:hover {
        color: white !important;
    }

    .sidebar .nav-link .badge {
        margin-top: 2px;
    }

    .profile-image .rounded-circle {
        border: 3px solid rgba(255, 255, 255, 0.2);
    }

    @media (max-width: 768px) {
        .sidebar {
            padding: 15px !important;
        }
    }
</style>