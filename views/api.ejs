<!-- views/api.ejs -->
<%- include('includes/header', { title: 'API Documentation - JobHub' , currentPage: 'api' }) %>

    <style>
        .api-hero {
            background: linear-gradient(135deg, #0b3d3f 0%, #1a5f5c 25%, #1e88a0 50%, #2c9ba8 75%, #3aa8c5 100%);
            padding: 60px 0 80px;
            position: relative;
            overflow: hidden;
        }

        .api-hero::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: floatApi 8s ease-in-out infinite;
        }

        .api-hero::after {
            content: '';
            position: absolute;
            bottom: -20%;
            left: -5%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            animation: floatApi 6s ease-in-out infinite reverse;
        }

        @keyframes floatApi {

            0%,
            100% {
                transform: translate(0, 0) rotate(0deg);
            }

            50% {
                transform: translate(30px, -30px) rotate(10deg);
            }
        }

        .api-container {
            background: white;
            border-radius: 1.5rem;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
            padding: 3rem;
            margin-top: -40px;
            position: relative;
            z-index: 1;
        }

        .api-endpoint {
            background: #f8f9fa;
            border-radius: 0.75rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border-left: 4px solid #1e88a0;
            transition: all 0.3s ease;
        }

        .api-endpoint:hover {
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            transform: translateX(5px);
        }

        .api-endpoint .method {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 0.5rem;
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            margin-right: 0.75rem;
        }

        .method-get {
            background: #d1e7dd;
            color: #0f5132;
        }

        .method-post {
            background: #cfe2ff;
            color: #084298;
        }

        .method-put {
            background: #fff3cd;
            color: #664d03;
        }

        .method-delete {
            background: #f8d7da;
            color: #842029;
        }

        .api-endpoint .endpoint-url {
            font-family: 'Courier New', monospace;
            font-size: 1rem;
            color: #0b3d3f;
            font-weight: 600;
        }

        .api-endpoint .description {
            color: #4a5568;
            margin-top: 0.5rem;
            font-size: 0.95rem;
        }

        .api-endpoint .auth-badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 0.5rem;
            font-size: 0.7rem;
            font-weight: 600;
            margin-left: 0.5rem;
        }

        .auth-badge.public {
            background: #d1e7dd;
            color: #0f5132;
        }

        .auth-badge.private {
            background: #f8d7da;
            color: #842029;
        }

        .auth-badge.employer {
            background: #cfe2ff;
            color: #084298;
        }

        .api-section-title {
            color: #0b3d3f;
            font-weight: 700;
            margin-bottom: 1.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 3px solid #e0f2f1;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .api-section-title i {
            color: #1e88a0;
        }

        .copy-btn {
            background: transparent;
            border: 1px solid #1e88a0;
            color: #1e88a0;
            padding: 0.25rem 0.75rem;
            border-radius: 0.5rem;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s ease;
            float: right;
        }

        .copy-btn:hover {
            background: #1e88a0;
            color: white;
        }

        .api-request-example {
            background: #1a1a2e;
            color: #e0e0e0;
            padding: 1rem;
            border-radius: 0.5rem;
            margin-top: 0.75rem;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
            overflow-x: auto;
            position: relative;
            white-space: pre-wrap;
            word-break: break-all;
        }

        .api-request-example .copy-btn-small {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #e0e0e0;
            padding: 0.2rem 0.6rem;
            border-radius: 0.3rem;
            font-size: 0.7rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .api-request-example .copy-btn-small:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .api-request-example .method-tag {
            display: inline-block;
            padding: 0.15rem 0.5rem;
            border-radius: 0.3rem;
            font-weight: 700;
            font-size: 0.7rem;
            text-transform: uppercase;
            margin-right: 0.5rem;
        }

        .method-tag.get {
            background: #0f5132;
            color: #d1e7dd;
        }

        .method-tag.post {
            background: #084298;
            color: #cfe2ff;
        }

        .method-tag.put {
            background: #664d03;
            color: #fff3cd;
        }

        .method-tag.delete {
            background: #842029;
            color: #f8d7da;
        }

        .toast-message {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #28a745;
            color: white;
            padding: 1rem 2rem;
            border-radius: 0.5rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            z-index: 9999;
            display: none;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from {
                transform: translateY(100px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .toast-message.error {
            background: #dc3545;
        }

        .badge-role {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 0.5rem;
            font-size: 0.7rem;
            font-weight: 600;
            background: #e9ecef;
            color: #495057;
        }

        @media (max-width: 768px) {
            .api-container {
                padding: 1.5rem;
                margin-top: -20px;
            }

            .api-endpoint {
                padding: 1rem;
            }

            .api-endpoint .endpoint-url {
                font-size: 0.85rem;
                word-break: break-all;
            }

            .api-request-example {
                font-size: 0.75rem;
                padding: 0.75rem;
            }

            .copy-btn {
                float: none;
                display: inline-block;
                margin-top: 0.5rem;
            }
        }

        @media (max-width: 576px) {
            .api-container {
                padding: 1rem;
            }

            .api-endpoint .method {
                font-size: 0.7rem;
                padding: 0.15rem 0.5rem;
            }

            .api-section-title {
                font-size: 1.1rem;
            }
        }
    </style>

    <!-- Toast Message -->
    <div class="toast-message" id="toastMessage">
        <i class="fa fa-check-circle me-2"></i>
        <span id="toastText">Copied to clipboard!</span>
    </div>

    <!-- API Hero Section -->
    <section class="api-hero">
        <div class="container text-center position-relative" style="z-index: 1;">
            <i class="fa fa-code fa-4x mb-4"></i>
            <h1 class="display-4 fw-bold text-white">REST API Documentation</h1>
            <p class="lead text-white-50">Complete API reference for JobHub platform</p>
            <div class="mt-3">
                <span class="badge bg-light text-dark me-2 p-2">
                    <i class="fa fa-check-circle text-success"></i> 20+ Endpoints
                </span>
                <span class="badge bg-light text-dark me-2 p-2">
                    <i class="fa fa-lock text-warning"></i> JWT Auth
                </span>
                <span class="badge bg-light text-dark p-2">
                    <i class="fa fa-database text-primary"></i> RESTful
                </span>
            </div>
        </div>
    </section>

    <div class="container">
        <div class="api-container">
            <!-- Base URL -->
            <div class="alert alert-info mb-4">
                <i class="fa fa-link me-2"></i>
                <strong>Base URL:</strong>
                <code class="bg-white px-2 py-1 rounded">http://localhost:3000/api</code>
                <button class="btn btn-sm btn-outline-primary ms-2" onclick="copyText('http://localhost:3000/api')">
                    <i class="fa fa-copy"></i> Copy
                </button>
            </div>

            <!-- Authentication Info -->
            <div class="alert alert-warning mb-4">
                <i class="fa fa-key me-2"></i>
                <strong>Authentication:</strong>
                <span class="badge bg-dark text-white ms-2">Bearer Token</span>
                <br>
                <small>Include in headers: <code>Authorization: Bearer {your_token}</code></small>
                <button class="btn btn-sm btn-outline-secondary ms-2"
                    onclick="copyText('Authorization: Bearer {your_token}')">
                    <i class="fa fa-copy"></i>
                </button>
            </div>

            <!-- ======== PUBLIC APIs ========== -->
            <h3 class="api-section-title">
                <i class="fa fa-globe"></i>
                Public APIs <span class="badge bg-success ms-2">No Auth Required</span>
            </h3>

            <!-- GET Jobs -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-get">GET</span>
                    <span class="endpoint-url">/jobs</span>
                    <span class="auth-badge public">Public</span>
                    <button class="copy-btn" onclick="copyText('GET http://localhost:3000/api/jobs')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Get all jobs with pagination and filters
                    <br>
                    <strong>Query Parameters:</strong>
                    <span class="badge-role">page</span>
                    <span class="badge-role">limit</span>
                    <span class="badge-role">search</span>
                    <span class="badge-role">type</span>
                    <span class="badge-role">location</span>
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick="copyText('GET http://localhost:3000/api/jobs?page=1&limit=10&search=developer')">
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag get">GET</span>
                    http://localhost:3000/api/jobs?page=1&limit=10&search=developer
                </div>
            </div>

            <!-- GET Single Job -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-get">GET</span>
                    <span class="endpoint-url">/jobs/:id</span>
                    <span class="auth-badge public">Public</span>
                    <button class="copy-btn" onclick="copyText('GET http://localhost:3000/api/jobs/{job_id}')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Get single job details by ID
                    <br>
                    <strong>Path Parameter:</strong>
                    <span class="badge-role">id</span> - Job ID (24 character hex string)
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick="copyText('GET http://localhost:3000/api/jobs/507f1f77bcf86cd799439011')">
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag get">GET</span>
                    http://localhost:3000/api/jobs/507f1f77bcf86cd799439011
                </div>
            </div>

            <!-- GET Featured Jobs -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-get">GET</span>
                    <span class="endpoint-url">/jobs/featured</span>
                    <span class="auth-badge public">Public</span>
                    <button class="copy-btn" onclick="copyText('GET http://localhost:3000/api/jobs/featured')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Get featured jobs (most viewed)
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small" onclick="copyText('GET http://localhost:3000/api/jobs/featured')">
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag get">GET</span>
                    http://localhost:3000/api/jobs/featured
                </div>
            </div>

            <!-- GET Categories -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-get">GET</span>
                    <span class="endpoint-url">/categories</span>
                    <span class="auth-badge public">Public</span>
                    <button class="copy-btn" onclick="copyText('GET http://localhost:3000/api/categories')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Get all job categories/types
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small" onclick="copyText('GET http://localhost:3000/api/categories')">
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag get">GET</span>
                    http://localhost:3000/api/categories
                </div>
            </div>

            <!-- GET Stats -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-get">GET</span>
                    <span class="endpoint-url">/stats</span>
                    <span class="auth-badge public">Public</span>
                    <button class="copy-btn" onclick="copyText('GET http://localhost:3000/api/stats')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Get platform statistics
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small" onclick="copyText('GET http://localhost:3000/api/stats')">
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag get">GET</span>
                    http://localhost:3000/api/stats
                </div>
            </div>

            <!-- ======== AUTH APIs ========== -->
            <h3 class="api-section-title mt-5">
                <i class="fa fa-lock"></i>
                Authentication APIs <span class="badge bg-warning ms-2">No Auth Required</span>
            </h3>

            <!-- POST Register -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-post">POST</span>
                    <span class="endpoint-url">/auth/register</span>
                    <span class="auth-badge public">Public</span>
                    <button class="copy-btn" onclick="copyText('POST http://localhost:3000/api/auth/register')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Register a new user
                    <br>
                    <strong>Body Parameters:</strong>
                    <span class="badge-role">email</span>
                    <span class="badge-role">password</span>
                    <span class="badge-role">fullname</span>
                    <span class="badge-role">accountType</span>
                    <span class="badge-role">phone</span>
                    <span class="badge-role">company</span>
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick='copyText("POST http://localhost:3000/api/auth/register\n\n{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"fullname\": \"John Doe\",\n  \"accountType\": \"jobseeker\",\n  \"phone\": \"+1234567890\"\n}")'>
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag post">POST</span>
                    http://localhost:3000/api/auth/register
                    <br><br>
                    {
                    <br>
                    &nbsp;&nbsp;"email": "user@example.com",
                    <br>
                    &nbsp;&nbsp;"password": "password123",
                    <br>
                    &nbsp;&nbsp;"fullname": "John Doe",
                    <br>
                    &nbsp;&nbsp;"accountType": "jobseeker",
                    <br>
                    &nbsp;&nbsp;"phone": "+1234567890"
                    <br>
                    }
                </div>
            </div>

            <!-- POST Login -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-post">POST</span>
                    <span class="endpoint-url">/auth/login</span>
                    <span class="auth-badge public">Public</span>
                    <button class="copy-btn" onclick="copyText('POST http://localhost:3000/api/auth/login')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Login user and get token
                    <br>
                    <strong>Body Parameters:</strong>
                    <span class="badge-role">email</span>
                    <span class="badge-role">password</span>
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick='copyText("POST http://localhost:3000/api/auth/login\n\n{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}")'>
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag post">POST</span>
                    http://localhost:3000/api/auth/login
                    <br><br>
                    {
                    <br>
                    &nbsp;&nbsp;"email": "user@example.com",
                    <br>
                    &nbsp;&nbsp;"password": "password123"
                    <br>
                    }
                </div>
            </div>

            <!-- ======== PROTECTED APIs ========== -->
            <h3 class="api-section-title mt-5">
                <i class="fa fa-user-shield"></i>
                Protected APIs <span class="badge bg-danger ms-2">Auth Required</span>
            </h3>

            <!-- GET Profile -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-get">GET</span>
                    <span class="endpoint-url">/auth/profile</span>
                    <span class="auth-badge private">Private</span>
                    <button class="copy-btn" onclick="copyText('GET http://localhost:3000/api/auth/profile')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Get current user profile
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick='copyText("GET http://localhost:3000/api/auth/profile\nAuthorization: Bearer {your_token}")'>
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag get">GET</span>
                    http://localhost:3000/api/auth/profile
                    <br>
                    Authorization: Bearer {your_token}
                </div>
            </div>

            <!-- PUT Profile -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-put">PUT</span>
                    <span class="endpoint-url">/auth/profile</span>
                    <span class="auth-badge private">Private</span>
                    <button class="copy-btn" onclick="copyText('PUT http://localhost:3000/api/auth/profile')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Update user profile
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick='copyText("PUT http://localhost:3000/api/auth/profile\nAuthorization: Bearer {your_token}\n\n{\n  \"fullname\": \"John Updated\",\n  \"phone\": \"+9876543210\",\n  \"bio\": \"Software Engineer\"\n}")'>
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag put">PUT</span>
                    http://localhost:3000/api/auth/profile
                    <br>
                    Authorization: Bearer {your_token}
                    <br><br>
                    {
                    <br>
                    &nbsp;&nbsp;"fullname": "John Updated",
                    <br>
                    &nbsp;&nbsp;"phone": "+9876543210",
                    <br>
                    &nbsp;&nbsp;"bio": "Software Engineer"
                    <br>
                    }
                </div>
            </div>

            <!-- POST Logout -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-post">POST</span>
                    <span class="endpoint-url">/auth/logout</span>
                    <span class="auth-badge private">Private</span>
                    <button class="copy-btn" onclick="copyText('POST http://localhost:3000/api/auth/logout')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Logout user (invalidate token)
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick='copyText("POST http://localhost:3000/api/auth/logout\nAuthorization: Bearer {your_token}")'>
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag post">POST</span>
                    http://localhost:3000/api/auth/logout
                    <br>
                    Authorization: Bearer {your_token}
                </div>
            </div>

            <!-- ======== JOB SEEKER APIs ========== -->
            <h3 class="api-section-title mt-5">
                <i class="fa fa-user"></i>
                Job Seeker APIs <span class="badge bg-info ms-2">Job Seeker + Auth</span>
            </h3>

            <!-- POST Apply -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-post">POST</span>
                    <span class="endpoint-url">/applications</span>
                    <span class="auth-badge private">Private</span>
                    <button class="copy-btn" onclick="copyText('POST http://localhost:3000/api/applications')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Apply for a job
                    <br>
                    <strong>Body Parameters:</strong>
                    <span class="badge-role">jobId</span>
                    <span class="badge-role">fullName</span>
                    <span class="badge-role">email</span>
                    <span class="badge-role">phone</span>
                    <span class="badge-role">coverLetter</span>
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick='copyText("POST http://localhost:3000/api/applications\nAuthorization: Bearer {your_token}\n\n{\n  \"jobId\": \"507f1f77bcf86cd799439011\",\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+1234567890\",\n  \"coverLetter\": \"I am very interested in this position...\"\n}")'>
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag post">POST</span>
                    http://localhost:3000/api/applications
                    <br>
                    Authorization: Bearer {your_token}
                    <br><br>
                    {
                    <br>
                    &nbsp;&nbsp;"jobId": "507f1f77bcf86cd799439011",
                    <br>
                    &nbsp;&nbsp;"fullName": "John Doe",
                    <br>
                    &nbsp;&nbsp;"email": "john@example.com",
                    <br>
                    &nbsp;&nbsp;"phone": "+1234567890",
                    <br>
                    &nbsp;&nbsp;"coverLetter": "I am very interested..."
                    <br>
                    }
                </div>
            </div>

            <!-- GET My Applications -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-get">GET</span>
                    <span class="endpoint-url">/applications/my</span>
                    <span class="auth-badge private">Private</span>
                    <button class="copy-btn" onclick="copyText('GET http://localhost:3000/api/applications/my')">
                        <i class="fa fa-copy"></i> Copy
                    </button>
                </div>
                <div class="description">
                    <strong>Description:</strong> Get all applications submitted by user
                </div>
                <div class="api-request-example">
                    <button class="copy-btn-small"
                        onclick='copyText("GET http://localhost:3000/api/applications/my\nAuthorization: Bearer {your_token}")'>
                        <i class="fa fa-copy"></i>
                    </button>
                    <span class="method-tag get">GET</span>
                    http://localhost:3000/api/applications/my
                    <br>
                    Authorization: Bearer {your_token}
                </div>
            </div>

            <!-- DELETE Application -->
            <div class="api-endpoint">
                <div>
                    <span class="method method-delete">DELETE</span>
                    <span class="endpoint-url">/applications/:id</span>
