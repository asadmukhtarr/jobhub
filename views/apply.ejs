<%- include('includes/header', { title: 'JobHub - Apply for Job' , currentPage: 'apply' }) %>

    <style>
        /* Apply Page Specific Styles */
        .apply-hero {
            background: linear-gradient(135deg, #0b3d3f 0%, #1a5f5c 25%, #1e88a0 50%, #2c9ba8 75%, #3aa8c5 100%);
            padding: 60px 0;
            position: relative;
            overflow: hidden;
        }

        .apply-hero::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: floatApply 8s ease-in-out infinite;
        }

        .apply-hero::after {
            content: '';
            position: absolute;
            bottom: -20%;
            left: -5%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            animation: floatApply 6s ease-in-out infinite reverse;
        }

        @keyframes floatApply {

            0%,
            100% {
                transform: translate(0, 0) rotate(0deg);
            }

            50% {
                transform: translate(30px, -30px) rotate(10deg);
            }
        }

        .job-preview-card {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border-left: 4px solid #1e88a0;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
        }

        .apply-card {
            background: white;
            border-radius: 1.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .apply-header {
            background: linear-gradient(135deg, #1e88a0, #3aa8c5);
            padding: 1.5rem;
            color: white;
        }

        .apply-body {
            padding: 2rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            font-weight: 500;
            color: #0b3d3f;
            margin-bottom: 0.5rem;
        }

        .form-label i {
            color: #1e88a0;
            margin-right: 0.5rem;
        }

        .form-label .required {
            color: #dc3545;
            margin-left: 0.25rem;
        }

        .input-group-custom {
            position: relative;
        }

        .input-group-custom .form-control,
        .input-group-custom .form-select {
            border: 1px solid #e0e0e0;
            border-radius: 0.5rem;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .input-group-custom .form-control:focus,
        .input-group-custom .form-select:focus {
            border-color: #1e88a0;
            box-shadow: 0 0 0 0.2rem rgba(30, 136, 160, 0.1);
            outline: none;
        }

        .input-group-custom .form-control.error {
            border-color: #dc3545;
        }

        .file-upload {
            position: relative;
            display: inline-block;
            width: 100%;
        }

        .file-upload-label {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.75rem;
            background: #f8f9fa;
            border: 2px dashed #1e88a0;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .file-upload-label:hover {
            background: #e0f2f1;
            border-color: #0b3d3f;
        }

        .file-upload-input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .file-name {
            margin-top: 0.5rem;
            font-size: 0.85rem;
            color: #666;
        }

        .btn-submit {
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            border: none;
            border-radius: 0.5rem;
            padding: 12px 30px;
            color: white;
            font-weight: 500;
            transition: all 0.3s ease;
            width: 100%;
        }

        .btn-submit:hover {
            background: linear-gradient(135deg, #2c9ba8, #3aa8c5);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(30, 136, 160, 0.4);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .alert-error {
            background: #fee;
            border-left: 4px solid #dc3545;
            color: #dc3545;
            padding: 0.75rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }

        .alert-success {
            background: #e0f2f1;
            border-left: 4px solid #1e88a0;
            color: #0b3d3f;
            padding: 0.75rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }

        .skill-tag {
            display: inline-flex;
            align-items: center;
            background: #e0f2f1;
            padding: 0.3rem 0.8rem;
            border-radius: 2rem;
            font-size: 0.8rem;
            margin: 0.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .skill-tag:hover {
            background: #1e88a0;
            color: white;
        }

        .skill-tag.selected {
            background: #1e88a0;
            color: white;
        }

        .application-stats {
            background: #f8f9fa;
            border-radius: 0.5rem;
            padding: 1rem;
            margin-bottom: 1rem;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up {
            animation: fadeInUp 0.6s ease forwards;
        }

        .progress-bar-custom {
            height: 4px;
            background: #e0e0e0;
            border-radius: 2px;
            overflow: hidden;
            margin-bottom: 1rem;
        }

        .progress-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #1e88a0, #3aa8c5);
            transition: width 0.3s ease;
        }
    </style>

    <!-- Apply Hero Section -->
    <section class="apply-hero">
        <div class="container text-center position-relative" style="z-index: 1;">
            <i class="fa fa-paper-plane fa-4x mb-4" style="animation: fadeInUp 0.6s ease;"></i>
            <h1 class="display-4 fw-bold" style="animation: fadeInUp 0.6s ease 0.1s backwards;">Job Application</h1>
            <p class="lead" style="animation: fadeInUp 0.6s ease 0.2s backwards;">Complete the form below to apply for
                your dream position</p>
        </div>
    </section>

    <div class="container mt-5 mb-5">
        <div class="row">
            <!-- Job Preview Sidebar -->
            <div class="col-lg-4 mb-4">
                <div class="job-preview-card">
                    <div class="d-flex align-items-start mb-3">
                        <div class="company-logo me-3"
                            style="width: 50px; height: 50px; background: linear-gradient(135deg, #e0f2f1, #b2dfdb); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                            <i class="fa fa-code fa-2x" style="color: #1e88a0;"></i>
                        </div>
                        <div>
                            <h5 class="mb-1" id="jobTitle">Frontend Developer</h5>
                            <p class="text-muted mb-0" id="companyName">TechCorp Inc.</p>
                        </div>
                    </div>
                    <div class="mb-2">
                        <i class="fa fa-map-marker" style="color: #1e88a0;"></i>
                        <span class="ms-2" id="jobLocation">Remote</span>
                    </div>
                    <div class="mb-2">
                        <i class="fa fa-usd" style="color: #1e88a0;"></i>
                        <span class="ms-2" id="jobSalary">$80k - $110k</span>
                    </div>
                    <div class="mb-2">
                        <i class="fa fa-clock-o" style="color: #1e88a0;"></i>
                        <span class="ms-2" id="jobType">Full-time</span>
                    </div>
                    <hr>
                    <div>
                        <strong>Required Skills:</strong>
                        <div class="mt-2" id="requiredSkills">
                            <span class="skill-tag">React</span>
                            <span class="skill-tag">JavaScript</span>
                            <span class="skill-tag">CSS</span>
                        </div>
                    </div>
                </div>

                <div class="application-stats">
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="fa fa-users"></i> Applicants</span>
                        <strong>47 applied</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="fa fa-calendar"></i> Deadline</span>
                        <strong>March 30, 2025</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span><i class="fa fa-clock-o"></i> Time Left</span>
                        <strong class="text-success">15 days left</strong>
                    </div>
                </div>

                <div class="alert-info"
                    style="background: #e3f2fd; padding: 1rem; border-radius: 0.5rem; border-left: 4px solid #1e88a0;">
                    <i class="fa fa-info-circle"></i>
                    <small>Make sure to upload your resume and cover letter. Incomplete applications will not be
                        considered.</small>
                </div>
            </div>

            <!-- Application Form -->
            <div class="col-lg-8">
                <div class="apply-card">
                    <div class="apply-header">
                        <i class="fa fa-file-text fa-2x mb-2"></i>
                        <h3 class="mb-0">Application Form</h3>
                        <p class="mb-0 opacity-75">Please fill out all required fields (*)</p>
                    </div>
                    <div class="apply-body">
                        <!-- Progress Bar -->
                        <div class="progress-bar-custom">
                            <div class="progress-fill" id="progressFill"></div>
                        </div>

                        <!-- Error Message -->
                        <div id="errorMessage" class="alert-error d-none">
                            <i class="fa fa-exclamation-triangle"></i> <span id="errorText"></span>
                        </div>

                        <!-- Success Message -->
                        <div id="successMessage" class="alert-success d-none">
                            <i class="fa fa-check-circle"></i> Application submitted successfully! We'll contact you
                            soon.
                        </div>
                        <form action="/apply/job" method="POST" id="applicationForm">
                            <!-- Hidden fields for job data -->
                            <input type="hidden" name="jobId" value="<%= job?._id || '' %>">
                            <input type="hidden" name="jobTitle" value="<%= job?.title || '' %>">
                            <input type="hidden" name="companyName" value="<%= job?.company || '' %>">

                            <!-- Error Messages -->
                            <% if (errors && errors.length> 0) { %>
                                <div class="alert-error">
                                    <i class="fa fa-exclamation-triangle"></i>
                                    <ul class="mb-0">
                                        <% errors.forEach(error=> { %>
                                            <li>
                                                <%= error %>
                                            </li>
                                            <% }) %>
                                    </ul>
                                </div>
                                <% } %>

                                    <% if (success) { %>
                                        <div class="alert-success">
                                            <i class="fa fa-check-circle"></i>
                                            <%= success %>
                                        </div>
                                        <% } %>

                                            <!-- Personal Information -->
                                            <h5 class="mb-3"><i class="fa fa-user" style="color: #1e88a0;"></i> Personal
                                                Information</h5>

                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-user"></i> Full Name
                                                            <span class="required">*</span></label>
                                                        <div class="input-group-custom">
                                                            <input type="text" class="form-control" id="fullname"
                                                                name="fullname" placeholder="John Doe"
                                                                value="<%= formData?.fullname || user?.userName || '' %>"
                                                                required>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-envelope"></i> Email
                                                            Address <span class="required">*</span></label>
                                                        <div class="input-group-custom">
                                                            <input type="email" class="form-control" id="email"
                                                                name="email" placeholder="john@example.com"
                                                                value="<%= formData?.email || user?.userEmail || '' %>"
                                                                required>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-phone"></i> Phone
                                                            Number <span class="required">*</span></label>
                                                        <div class="input-group-custom">
                                                            <input type="tel" class="form-control" id="phone"
                                                                name="phone" placeholder="+1 234 567 8900"
                                                                value="<%= formData?.phone || '' %>" required>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-map-marker"></i>
                                                            Current Location</label>
                                                        <div class="input-group-custom">
                                                            <input type="text" class="form-control" id="location"
                                                                name="location" placeholder="City, State"
                                                                value="<%= formData?.location || '' %>">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Professional Information -->
                                            <h5 class="mb-3 mt-4"><i class="fa fa-briefcase"
                                                    style="color: #1e88a0;"></i> Professional Information</h5>

                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-graduation-cap"></i>
                                                            Highest Education <span class="required">*</span></label>
                                                        <div class="input-group-custom">
                                                            <select class="form-select" id="education" name="education"
                                                                required>
                                                                <option value="">Select education level</option>
                                                                <option value="High School Diploma"
                                                                    <%=formData?.education==='High School Diploma'
                                                                    ? 'selected' : '' %>>High School Diploma</option>
                                                                <option value="Associate Degree"
                                                                    <%=formData?.education==='Associate Degree'
                                                                    ? 'selected' : '' %>>Associate Degree</option>
                                                                <option value="Bachelor's Degree"
                                                                    <%=formData?.education==="Bachelor's Degree"
                                                                    ? 'selected' : '' %>>Bachelor's Degree</option>
                                                                <option value="Master's Degree"
                                                                    <%=formData?.education==="Master's Degree"
                                                                    ? 'selected' : '' %>>Master's Degree</option>
                                                                <option value="PhD/Doctorate"
                                                                    <%=formData?.education==='PhD/Doctorate'
                                                                    ? 'selected' : '' %>>PhD/Doctorate</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-calendar"></i> Years
                                                            of Experience <span class="required">*</span></label>
                                                        <div class="input-group-custom">
                                                            <select class="form-select" id="experience"
                                                                name="experience" required>
                                                                <option value="">Select experience</option>
                                                                <option value="Fresh Graduate (0-1 years)"
                                                                    <%=formData?.experience==='Fresh Graduate (0-1 years)'
                                                                    ? 'selected' : '' %>>Fresh Graduate (0-1 years)
                                                                </option>
                                                                <option value="Entry Level (1-3 years)"
                                                                    <%=formData?.experience==='Entry Level (1-3 years)'
                                                                    ? 'selected' : '' %>>Entry Level (1-3 years)
                                                                </option>
                                                                <option value="Mid Level (3-5 years)"
                                                                    <%=formData?.experience==='Mid Level (3-5 years)'
                                                                    ? 'selected' : '' %>>Mid Level (3-5 years)</option>
                                                                <option value="Senior Level (5-8 years)"
                                                                    <%=formData?.experience==='Senior Level (5-8 years)'
                                                                    ? 'selected' : '' %>>Senior Level (5-8 years)
                                                                </option>
                                                                <option value="Expert (8+ years)"
                                                                    <%=formData?.experience==='Expert (8+ years)'
                                                                    ? 'selected' : '' %>>Expert (8+ years)</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group">
                                                <label class="form-label"><i class="fa fa-code"></i> Skills <span
                                                        class="required">*</span></label>
                                                <div class="input-group-custom">
                                                    <input type="text" class="form-control" id="skills" name="skills"
                                                        placeholder="React, Node.js, Python, etc."
                                                        value="<%= formData?.skills || '' %>" required>
                                                </div>
                                                <small class="text-muted">Separate skills with commas</small>
                                            </div>

                                            <div class="form-group">
                                                <label class="form-label"><i class="fa fa-file-text"></i> Cover Letter
                                                    <span class="required">*</span></label>
                                                <div class="input-group-custom">
                                                    <textarea class="form-control" id="coverLetter" name="coverLetter"
                                                        rows="5"
                                                        placeholder="Tell us why you're the perfect fit for this position..."
                                                        required><%= formData?.coverLetter || '' %></textarea>
                                                </div>
                                            </div>

                                            <!-- Additional Information -->
                                            <div class="form-group">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="workAuth"
                                                        name="workAuth" <%=formData?.workAuth ? 'checked' : '' %>
                                                    required>
                                                    <label class="form-check-label" for="workAuth">
                                                        <i class="fa fa-check-circle-o"></i> I confirm that I have the
                                                        legal right to work in this country <span
                                                            class="required">*</span>
                                                    </label>
                                                </div>
                                            </div>

                                            <div class="form-group">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox"
                                                        id="notificationConsent" name="notificationConsent"
                                                        <%=formData?.notificationConsent ? 'checked' : '' %>>
                                                    <label class="form-check-label" for="notificationConsent">
                                                        <i class="fa fa-bell"></i> Send me notifications about my
                                                        application status
                                                    </label>
                                                </div>
                                            </div>

                                            <button type="submit" class="btn-submit" id="submitBtn">
                                                <i class="fa fa-send"></i> Submit Application
                                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Get job parameters from URL
        const urlParams = new URLSearchParams(window.location.search);
        const jobParam = urlParams.get('job');

        // Job data based on parameter
        const jobData = {
            'frontend': {
                title: 'Frontend Developer',
                company: 'TechCorp Inc.',
                location: 'Remote',
                salary: '$80k - $110k',
                type: 'Full-time',
                skills: ['React', 'JavaScript', 'CSS', 'HTML', 'Tailwind']
            },
            'data-scientist': {
                title: 'Data Scientist',
                company: 'DataMind AI',
                location: 'Hybrid',
                salary: '$100k - $140k',
                type: 'Full-time',
                skills: ['Python', 'Machine Learning', 'SQL', 'TensorFlow', 'Pandas']
            },
            'cloud-engineer': {
                title: 'Cloud Engineer',
                company: 'CloudScale',
                location: 'Onsite',
                salary: '$95k - $125k',
                type: 'Full-time',
                skills: ['AWS', 'Kubernetes', 'Docker', 'Terraform', 'Linux']
            },
            'senior-fullstack': {
                title: 'Senior Full Stack Developer',
                company: 'Google',
                location: 'Remote',
                salary: '$120k - $160k',
                type: 'Full-time',
                skills: ['React', 'Node.js', 'MongoDB', 'AWS', 'TypeScript']
            },
            'ui-ux-designer': {
                title: 'UI/UX Designer',
                company: 'Microsoft',
                location: 'Hybrid',
                salary: '$90k - $130k',
                type: 'Full-time',
                skills: ['Figma', 'Adobe XD', 'Sketch', 'Prototyping', 'User Research']
            },
            'devops-engineer': {
                title: 'DevOps Engineer',
                company: 'Amazon Web Services',
                location: 'Onsite',
                salary: '$130k - $180k',
                type: 'Full-time',
                skills: ['Docker', 'Kubernetes', 'Jenkins', 'AWS', 'Terraform']
            },
            'data-engineer': {
                title: 'Data Engineer',
                company: 'Meta',
                location: 'Remote',
                salary: '$110k - $150k',
                type: 'Full-time',
                skills: ['Python', 'SQL', 'Spark', 'Airflow', 'Big Data']
            },
            'ios-developer': {
                title: 'iOS Mobile Developer',
                company: 'Apple',
                location: 'Hybrid',
                salary: '$115k - $155k',
                type: 'Full-time',
                skills: ['Swift', 'SwiftUI', 'iOS', 'CoreData', 'UIKit']
            }
        };

        // Default job data
        let currentJob = jobData[jobParam] || jobData['frontend'];

        // Update job preview
        document.getElementById('jobTitle').textContent = currentJob.title;
        document.getElementById('companyName').textContent = currentJob.company;
        document.getElementById('jobLocation').textContent = currentJob.location;
        document.getElementById('jobSalary').textContent = currentJob.salary;
        document.getElementById('jobType').textContent = currentJob.type;

        // Update required skills
        const skillsContainer = document.getElementById('requiredSkills');
        skillsContainer.innerHTML = '';
        currentJob.skills.forEach(skill => {
            const tag = document.createElement('span');
            tag.className = 'skill-tag';
            tag.textContent = skill;
            skillsContainer.appendChild(tag);
        });

        // File upload handlers
        document.getElementById('resume').addEventListener('change', function (e) {
            const fileName = e.target.files[0]?.name || 'No file chosen';
            document.getElementById('resumeName').textContent = fileName;
        });

        document.getElementById('portfolio').addEventListener('change', function (e) {
            const fileName = e.target.files[0]?.name || 'No file chosen';
            document.getElementById('portfolioName').textContent = fileName;
        });

        // Phone number formatting
        const phoneInput = document.getElementById('phone');
        phoneInput.addEventListener('input', function (e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length > 10) value = value.slice(0, 10);
            if (value.length >= 6) {
                value = value.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3');
            } else if (value.length >= 3) {
                value = value.replace(/(\d{3})(\d+)/, '($1) $2');
            }
            e.target.value = value;
        });

        // Form validation and progress tracking
        const formInputs = document.querySelectorAll('#applicationForm input, #applicationForm select, #applicationForm textarea');
        const progressFill = document.getElementById('progressFill');

        function updateProgress() {
            let totalFields = 0;
            let filledFields = 0;

            formInputs.forEach(input => {
                if (input.type !== 'file' && input.type !== 'checkbox' && input.hasAttribute('required')) {
                    totalFields++;
                    if (input.value.trim() !== '') {
                        filledFields++;
                    }
                } else if (input.type === 'checkbox' && input.hasAttribute('required')) {
                    totalFields++;
                    if (input.checked) {
                        filledFields++;
                    }
                } else if (input.type === 'file' && input.hasAttribute('required')) {
                    totalFields++;
                    if (input.files.length > 0) {
                        filledFields++;
                    }
                }
            });

            const percentage = (filledFields / totalFields) * 100;
            progressFill.style.width = percentage + '%';
        }

        formInputs.forEach(input => {
            input.addEventListener('change', updateProgress);
            input.addEventListener('input', updateProgress);
        });

        // Form submission
        const applicationForm = document.getElementById('applicationForm');
        const errorMessage = document.getElementById('errorMessage');
        const errorText = document.getElementById('errorText');
        const successMessage = document.getElementById('successMessage');

        applicationForm.addEventListener('submit', function (e) {
            e.preventDefault();

            errorMessage.classList.add('d-none');

            // Get form values
            const fullname = document.getElementById('fullname').value;
            const email = document.getElementById('email').value;
            const phone = document.getElementById('phone').value;
            const education = document.getElementById('education').value;
            const experience = document.getElementById('experience').value;
            const skills = document.getElementById('skills').value;
            const coverLetter = document.getElementById('coverLetter').value;
            const resume = document.getElementById('resume').files[0];
            const workAuth = document.getElementById('workAuth').checked;

            // Validation
            if (!fullname) {
                errorText.textContent = 'Please enter your full name.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!email || !email.includes('@')) {
                errorText.textContent = 'Please enter a valid email address.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!phone) {
                errorText.textContent = 'Please enter your phone number.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!education) {
                errorText.textContent = 'Please select your education level.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!experience) {
                errorText.textContent = 'Please select your experience level.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!skills) {
                errorText.textContent = 'Please enter your skills.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!coverLetter) {
                errorText.textContent = 'Please write a cover letter.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!resume) {
                errorText.textContent = 'Please upload your resume.';
                errorMessage.classList.remove('d-none');
                return;
            }

            if (!workAuth) {
                errorText.textContent = 'Please confirm your work authorization.';
                errorMessage.classList.remove('d-none');
                return;
            }

            // Store application data (demo)
            const applicationData = {
                job: currentJob.title,
                company: currentJob.company,
                fullname: fullname,
                email: email,
                phone: phone,
                location: document.getElementById('location').value,
                education: education,
                experience: experience,
                skills: skills,
                coverLetter: coverLetter,
                workAuth: workAuth,
                notificationConsent: document.getElementById('notificationConsent').checked,
                appliedAt: new Date().toISOString()
            };

            localStorage.setItem('lastApplication', JSON.stringify(applicationData));

            // Show success message
            successMessage.classList.remove('d-none');

            // Reset form
            applicationForm.reset();
            document.getElementById('resumeName').textContent = 'No file chosen';
            document.getElementById('portfolioName').textContent = 'No file chosen';
            updateProgress();

            // Scroll to success message
            successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });

            // Redirect after 3 seconds
            setTimeout(() => {
                window.location.href = '/jobs';
            }, 3000);
        });

        // Initial progress update
        updateProgress();
    </script>

