                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center mx-auto"
                            style="width: 80px; height: 80px;">
                            <i class="fa fa-user fa-3x text-white"></i>
                        </div>
                    </div>
                    <h6 class="mb-1">
                        <%= userName || 'John Doe' %>
                    </h6>
                    <small class="text-muted">
                        <%= userEmail || 'john@example.com' %>
                    </small>
                </div>

                <!-- Navigation Menu -->
                <nav class="nav flex-column">
                    <a href="/dashboard" class="nav-link text-white active mb-2">
                        <i class="fa fa-dashboard me-2"></i> Dashboard
                    </a>
                    <a href="/jobs/create" class="nav-link text-white-50 mb-2">
                        <i class="fa fa-plus-circle me-2"></i> Post New Job
                    </a>
                    <a href="/my-jobs" class="nav-link text-white-50 mb-2">
                        <i class="fa fa-briefcase me-2"></i> My Jobs
                    </a>
                    <a href="/applications" class="nav-link text-white-50 mb-2">
                        <i class="fa fa-file-text me-2"></i> Applications
                        <span class="badge bg-danger float-end">3</span>
                    </a>
                    <a href="/shortlisted" class="nav-link text-white-50 mb-2">
                        <i class="fa fa-star me-2"></i> Shortlisted
                    </a>
                    <a href="/messages" class="nav-link text-white-50 mb-2">
                        <i class="fa fa-envelope me-2"></i> Messages
                        <span class="badge bg-info float-end">5</span>
                    </a>
                    <a href="/profile" class="nav-link text-white-50 mb-2">
                        <i class="fa fa-user-circle me-2"></i> Profile Settings
                    </a>
                    <a href="/change-password" class="nav-link text-white-50 mb-2">
                        <i class="fa fa-key me-2"></i> Change Password
                    </a>
                    <hr class="bg-secondary">
                    <a href="/logout" class="nav-link text-danger mb-2">
                        <i class="fa fa-sign-out me-2"></i> Logout
                    </a>
                </nav>

                <!-- Stats Section -->
                <div class="mt-auto pt-4 border-top border-secondary">
                    <div class="small text-muted mb-2">Quick Stats</div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Total Jobs:</span>
                        <strong class="text-white">12</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Active Jobs:</span>
                        <strong class="text-success">8</strong>
                    </div>
