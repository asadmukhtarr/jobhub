<style>
    /* Custom Styles */
    .dashboard-container {
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    .sidebar {
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .sidebar::-webkit-scrollbar {
        width: 5px;
    }

    .sidebar::-webkit-scrollbar-track {
        background: #2c3e50;
    }

    .sidebar::-webkit-scrollbar-thumb {
        background: #3498db;
    }

    .nav-link {
        transition: all 0.3s ease;
        border-radius: 5px;
    }

    .nav-link:hover {
        background-color: rgba(255, 255, 255, 0.1);
        color: white !important;
        padding-left: 15px;
    }

    .nav-link.active {
        background-color: #3498db;
        color: white !important;
    }

    .stats-icon {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
    }

    .border-left-primary {
        border-left: 4px solid #3498db;
    }

    .border-left-success {
        border-left: 4px solid #28a745;
    }

    .border-left-info {
        border-left: 4px solid #17a2b8;
    }

    .border-left-warning {
        border-left: 4px solid #ffc107;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .welcome-banner {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .card {
        border: none;
        transition: transform 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    .btn-light {
        background: white;
        color: #667eea;
    }

    .btn-light:hover {
        background: #f8f9fa;
        transform: scale(1.05);
    }

    @media (max-width: 768px) {
        .sidebar {
            position: fixed;
            left: -100%;
            transition: left 0.3s;
            z-index: 1000;
        }

        .sidebar.show {
            left: 0;
        }

        .main-content {
            margin-left: 0 !important;
        }
    }
</style>