<style>
    /* Green & Blue Gradient Footer */
    .footer-gradient {
        background: linear-gradient(135deg, #0b3d3f 0%, #1a5f5c 25%, #1e88a0 50%, #2c9ba8 75%, #3aa8c5 100%);
        position: relative;
        overflow: hidden;
    }

    /* Animated wave effect at the top of footer */
    .footer-gradient::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #ffd700, #ff9800, #ffd700);
        animation: shimmer 2s infinite;
    }

    @keyframes shimmer {
        0% {
            opacity: 0.5;
        }

        50% {
            opacity: 1;
        }

        100% {
            opacity: 0.5;
        }
    }

    /* Social icons styling */
    .social-icon {
        display: inline-block;
        transition: all 0.3s ease;
        font-size: 1.6rem;
        margin-right: 1rem;
        opacity: 0.9;
    }

    .social-icon:hover {
        transform: translateY(-5px) scale(1.1);
        opacity: 1;
        color: #ffd700 !important;
        text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
    }

    /* Footer links styling */
    .footer-link {
        display: inline-block;
        transition: all 0.3s ease;
        margin-bottom: 8px;
    }

    .footer-link:hover {
        transform: translateX(8px);
        opacity: 1 !important;
        color: #ffd700 !important;
    }

    .footer-link i {
        margin-right: 6px;
        transition: all 0.3s ease;
    }

    .footer-link:hover i {
        transform: rotate(90deg);
    }

    /* Newsletter input styling */
    .newsletter-input {
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        transition: all 0.3s ease;
    }

    .newsletter-input:focus {
        background: rgba(255, 255, 255, 0.25);
        border-color: #ffd700;
        box-shadow: 0 0 0 0.2rem rgba(255, 215, 0, 0.25);
        color: white;
    }

    .newsletter-input::placeholder {
        color: rgba(255, 255, 255, 0.7);
    }

    .btn-newsletter {
        background: linear-gradient(135deg, #ffd700, #ff9800);
        color: #0b3d3f;
        border: none;
        transition: all 0.3s ease;
        font-weight: bold;
    }

    .btn-newsletter:hover {
        transform: scale(1.05);
        background: linear-gradient(135deg, #ffe44d, #ffb347);
        box-shadow: 0 0 15px rgba(255, 215, 0, 0.5);
    }

    .btn-newsletter i {
        transition: transform 0.3s ease;
    }

    .btn-newsletter:hover i {
        transform: translateX(3px);
    }

    /* Footer divider */
    .footer-divider {
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        margin: 1rem 0;
    }

    /* Section headings in footer */
    .footer-gradient h5,
    .footer-gradient h6 {
        font-weight: 600;
        margin-bottom: 1.2rem;
        position: relative;
        display: inline-block;
    }

    .footer-gradient h5::after,
    .footer-gradient h6::after {
        content: '';
        position: absolute;
        bottom: -8px;
        left: 0;
        width: 40px;
        height: 3px;
        background: linear-gradient(90deg, #ffd700, #ff9800);
        border-radius: 2px;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {

        .footer-gradient h5::after,
        .footer-gradient h6::after {
            width: 30px;
        }

        .social-icon {
            font-size: 1.4rem;
            margin-right: 0.8rem;
        }
    }

    /* Smooth scroll to top button (optional) */
    .scroll-to-top {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: linear-gradient(135deg, #1e88a0, #3aa8c5);
        color: white;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 1000;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .scroll-to-top.show {
        opacity: 1;
        visibility: visible;
    }

    .scroll-to-top:hover {
        transform: translateY(-5px);
        background: linear-gradient(135deg, #ffd700, #ff9800);
        color: #0b3d3f;
    }
</style>

<!-- Scroll to Top Button -->
<div class="scroll-to-top" id="scrollToTop">
    <i class="fa fa-arrow-up"></i>
</div>

<script>
    // Scroll to Top functionality
    const scrollBtn = document.getElementById('scrollToTop');

    window.addEventListener('scroll', function () {
        if (window.scrollY > 300) {
            scrollBtn.classList.add('show');
        } else {
            scrollBtn.classList.remove('show');
        }
    });

    scrollBtn.addEventListener('click', function () {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });

    // Newsletter subscription alert
    document.querySelector('.btn-newsletter')?.addEventListener('click', function () {
        const emailInput = document.querySelector('.newsletter-input');
        if (emailInput && emailInput.value) {
            alert('Thank you for subscribing to JobHub newsletter! 🎉');
            emailInput.value = '';
        } else if (emailInput) {
            alert('Please enter your email address to subscribe! 📧');
        }
    });
</script>

