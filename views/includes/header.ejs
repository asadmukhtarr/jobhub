<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'JobHub - Find Your Dream Job' %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 4 Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        main {
            flex: 1;
        }

        .navbar-brand i,
        .nav-link i {
            margin-right: 6px;
        }

        .footer-links a {
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .footer-links a:hover {
            opacity: 0.8;
            text-decoration: underline;
        }

        .social-icons a {
            font-size: 1.4rem;
            margin-right: 1rem;
            color: white;
            transition: transform 0.2s;
            display: inline-block;
        }

        .social-icons a:hover {
            transform: scale(1.1);
        }

        /* Green & Blue Gradient Header */
        .navbar-gradient {
            background: linear-gradient(135deg, #0b3d3f 0%, #1a5f5c 25%, #1e88a0 50%, #2c9ba8 75%, #3aa8c5 100%);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            padding: 0.8rem 0;
            transition: all 0.3s ease;
        }

        .navbar-gradient .navbar-brand {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ffffff, #e0f7fa);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent !important;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .navbar-gradient .navbar-brand:hover {
            transform: scale(1.05);
        }

        .navbar-gradient .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
            font-weight: 500;
            margin: 0 5px;
            padding: 8px 16px;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
        }

        .navbar-gradient .nav-link:hover {
            background: rgba(255, 255, 255, 0.2);
            color: white !important;
            transform: translateY(-2px);
        }

        .navbar-gradient .nav-link.active {
            background: rgba(255, 255, 255, 0.25);
            color: white !important;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .navbar-gradient .nav-link.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 30px;
            height: 3px;
            background: white;
            border-radius: 2px;
        }

        .navbar-gradient .dropdown-toggle {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 8px;
        }

        .navbar-gradient .dropdown-toggle:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .navbar-gradient .dropdown-menu {
            background: linear-gradient(135deg, #1a5f5c, #2c9ba8);
            border: none;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            margin-top: 10px;
            padding: 8px 0;
        }

        .navbar-gradient .dropdown-item {
            color: white;
            padding: 10px 20px;
            transition: all 0.3s ease;
            border-radius: 8px;
            margin: 2px 8px;
        }

        .navbar-gradient .dropdown-item:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateX(5px);
        }

        .navbar-gradient .dropdown-item i {
            margin-right: 8px;
        }

        .navbar-gradient .dropdown-divider {
            border-top-color: rgba(255, 255, 255, 0.2);
            margin: 8px 0;
        }

        /* Animated button effect */
        .navbar-toggler {
            border: 2px solid rgba(255, 255, 255, 0.5);
            background: rgba(255, 255, 255, 0.1);
        }

        .navbar-toggler:focus {
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.3);
        }

        /* Scroll effect */
        .navbar-gradient.scrolled {
            padding: 0.5rem 0;
            background: linear-gradient(135deg, #0b3d3f 0%, #1e88a0 100%);
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .navbar-gradient {
            animation: slideIn 0.5s ease;
        }
    </style>
</head>

<body>

    <!-- Navigation Header with Green & Blue Gradient -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-gradient shadow-lg" id="mainNavbar">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">
                    <i class="fa fa-briefcase"></i> JobHub
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'home' ? 'active' : '' %>" href="/">
                                <i class="fa fa-home"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'jobs' ? 'active' : '' %>" href="/jobs">
                                <i class="fa fa-search"></i> Jobs
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'about' ? 'active' : '' %>" href="/about">
                                <i class="fa fa-info-circle"></i> About
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'contact' ? 'active' : '' %>" href="/contact">
                                <i class="fa fa-envelope"></i> Contact
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="accountDropdown" role="button"
                                data-bs-toggle="dropdown">
                                <i class="fa fa-user-circle"></i> Account
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <% if (typeof isLoggedIn !=='undefined' && isLoggedIn) { %>
                                    <!-- Show when user is logged in -->
                                    <li>
                                        <a class="dropdown-item" href="/dashboard">
                                            <i class="fa fa-dashboard"></i> Dashboard
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/settings">
                                            <i class="fa fa-plus-circle"></i> Settings
                                        </a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="/logout">
                                            <i class="fa fa-sign-out"></i> Logout
                                        </a>
                                    </li>
                                    <% } else { %>
                                        <!-- Show when user is NOT logged in -->
                                        <li>
                                            <a class="dropdown-item <%= currentPage === 'login' ? 'active' : '' %>"
                                                href="/login">
                                                <i class="fa fa-sign-in"></i> Login
                                            </a>
                                        </li>
                                        <li>
                                            <hr class="dropdown-divider">
                                        </li>
                                        <li>
                                            <a class="dropdown-item <%= currentPage === 'register' ? 'active' : '' %>"
                                                href="/register">
                                                <i class="fa fa-user-plus"></i> Register
                                            </a>
                                        </li>
                                        <% } %>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <!-- Add this script for scroll effect -->
        <script>
            // Add scroll effect to navbar
            window.addEventListener('scroll', function () {
                const navbar = document.getElementById('mainNavbar');
                if (window.scrollY > 50) {
                    navbar.classList.add('scrolled');
                } else {
                    navbar.classList.remove('scrolled');
                }
            });
        </script>