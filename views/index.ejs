<!-- views/index.ejs -->
<%- include('includes/header', { title: 'JobHub - Find Your Dream Job' , currentPage: 'home' }) %>

    <style>
        /* Hero Section with Green & Blue Gradient */
        .hero-section {
            background: linear-gradient(135deg, #0b3d3f 0%, #1a5f5c 25%, #1e88a0 50%, #2c9ba8 75%, #3aa8c5 100%);
            color: white;
            padding: 100px 0;
            border-radius: 0 0 3rem 3rem;
            margin-bottom: 3rem;
            position: relative;
            overflow: hidden;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
        }

        .hero-section::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -5%;
            width: 250px;
            height: 250px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: float 8s ease-in-out infinite reverse;
        }

        @keyframes float {

            0%,
            100% {
                transform: translate(0, 0) rotate(0deg);
            }

            50% {
                transform: translate(20px, -20px) rotate(10deg);
            }
        }

        /* Category badges */
        .category-badge {
            background: linear-gradient(135deg, #e0f2f1, #b2dfdb);
            padding: 0.7rem 1.5rem;
            border-radius: 2rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
            font-weight: 500;
            color: #0b3d3f;
            text-decoration: none;
        }

        .category-badge:hover {
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            color: white;
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(30, 136, 160, 0.3);
        }

        .category-badge:hover i {
            color: white;
        }

        /* Job Cards */
        .job-card {
            border: none;
            border-radius: 1rem;
            transition: all 0.3s ease;
            background: white;
            position: relative;
            overflow: hidden;
            height: 100%;
        }

        .job-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #1e88a0, #3aa8c5, #ffd700);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .job-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        }

        .job-card:hover::before {
            transform: scaleX(1);
        }

        /* Buttons */
        .btn-gradient {
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            border: none;
            color: white;
            transition: all 0.3s ease;
        }

        .btn-gradient:hover {
            background: linear-gradient(135deg, #2c9ba8, #3aa8c5);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(30, 136, 160, 0.4);
            color: white;
        }

        .btn-outline-gradient {
            background: transparent;
            border: 2px solid #1e88a0;
            color: #1e88a0;
            transition: all 0.3s ease;
        }

        .btn-outline-gradient:hover {
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            color: white;
            transform: translateY(-2px);
            border-color: transparent;
        }

        /* Features Section */
        .features-section {
            background: linear-gradient(135deg, #e0f2f1, #b2dfdb);
            border-radius: 2rem;
            padding: 3rem;
            margin-bottom: 3rem;
        }

        .feature-icon {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #1e88a0, #3aa8c5);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
        }

        .feature-box:hover .feature-icon {
            transform: scale(1.1);
        }

        /* CTA Card */
        .cta-card {
            background: linear-gradient(135deg, #1e88a0, #0b3d3f);
            border: none;
            border-radius: 1.5rem;
            transition: transform 0.3s ease;
        }

        .cta-card:hover {
            transform: scale(1.02);
        }

        /* Statistics */
        .stat-number {
            font-size: 2.5rem;
            font-weight: bold;
            background: linear-gradient(135deg, #1e88a0, #ffd700);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        /* Job tags */
        .job-tag {
            background: #e8f5e9;
            padding: 0.2rem 0.6rem;
            border-radius: 0.5rem;
            font-size: 0.75rem;
            color: #1e88a0;
        }

        /* Testimonial cards */
        .testimonial-card {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(30, 136, 160, 0.1);
            height: 100%;
        }

        .testimonial-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border-color: #1e88a0;
        }

        /* Empty state */
        .empty-state {
            padding: 3rem;
            background: #f8f9fa;
            border-radius: 1rem;
            text-align: center;
        }

        .empty-state i {
            font-size: 4rem;
            color: #dee2e6;
            margin-bottom: 1rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero-section {
                padding: 60px 0;
            }

            .hero-section h1 {
                font-size: 2rem;
            }

            .features-section {
                padding: 1.5rem;
            }

            .stat-number {
                font-size: 1.8rem;
            }

            .category-badge {
                padding: 0.5rem 1rem;
                font-size: 0.8rem;
            }

            .job-card .card-title {
                font-size: 1rem;
            }
        }

        @media (max-width: 576px) {
            .hero-section {
                padding: 40px 0;
            }

            .hero-section h1 {
                font-size: 1.5rem;
            }

            .btn-lg {
                font-size: 0.9rem;
                padding: 0.5rem 1rem;
            }

            .stat-number {
                font-size: 1.5rem;
            }
        }
    </style>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container text-center position-relative" style="z-index: 1;">
            <i class="fa fa-rocket fa-4x mb-4"></i>
            <h1 class="display-4 fw-bold">Find Your Dream Job Today</h1>
            <p class="lead mt-3">Thousands of opportunities waiting for you. Join the future of work.</p>
            <div class="mt-4">
                <a href="/jobs" class="btn btn-light btn-lg me-3">
                    <i class="fa fa-briefcase"></i> Browse Jobs
                </a>
                <a href="/register" class="btn btn-outline-light btn-lg">
                    <i class="fa fa-user-plus"></i> Get Started
                </a>
            </div>
        </div>
    </section>

    <div class="container">
        <!-- Statistics Section -->
        <div class="row text-center mb-5 g-4">
            <div class="col-md-3 col-6">
                <div class="stat-number counter" data-target="<%= totalJobs || 0 %>">
                    <%= totalJobs || 0 %>
                </div>
                <p class="text-muted"><i class="fa fa-briefcase"></i> Jobs Posted</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number counter" data-target="<%= totalCompanies || 0 %>">
                    <%= totalCompanies || 0 %>
                </div>
                <p class="text-muted"><i class="fa fa-building"></i> Companies</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number counter" data-target="<%= totalCandidates || 0 %>">
                    <%= totalCandidates || 0 %>
                </div>
                <p class="text-muted"><i class="fa fa-users"></i> Happy Candidates</p>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-number counter" data-target="<%= satisfactionRate || 0 %>">
                    <%= satisfactionRate || 0 %>
                </div>
                <p class="text-muted"><i class="fa fa-smile-o"></i> Satisfaction Rate%</p>
            </div>
        </div>

        <!-- Popular Categories -->
        <div class="row mb-5">
            <div class="col-12 text-center mb-4">
                <h2><i class="fa fa-tags" style="color: #1e88a0;"></i> Popular Categories</h2>
                <p class="text-muted">Explore jobs by industry</p>
            </div>
            <div class="col-md-2 col-4 mb-3 text-center">
                <a href="/jobs?category=technology" class="category-badge">
                    <i class="fa fa-code"></i> Technology
                </a>
            </div>
            <div class="col-md-2 col-4 mb-3 text-center">
                <a href="/jobs?category=marketing" class="category-badge">
                    <i class="fa fa-line-chart"></i> Marketing
                </a>
            </div>
            <div class="col-md-2 col-4 mb-3 text-center">
                <a href="/jobs?category=finance" class="category-badge">
                    <i class="fa fa-pie-chart"></i> Finance
                </a>
            </div>
            <div class="col-md-2 col-4 mb-3 text-center">
                <a href="/jobs?category=healthcare" class="category-badge">
                    <i class="fa fa-medkit"></i> Healthcare
                </a>
            </div>
            <div class="col-md-2 col-4 mb-3 text-center">
                <a href="/jobs?category=sales" class="category-badge">
                    <i class="fa fa-shopping-cart"></i> Sales
                </a>
            </div>
            <div class="col-md-2 col-4 mb-3 text-center">
                <a href="/jobs?category=design" class="category-badge">
                    <i class="fa fa-paint-brush"></i> Design
                </a>
            </div>
        </div>

        <!-- Featured Jobs -->
        <div class="row mb-5">
            <div class="col-12 text-center mb-4">
                <h2><i class="fa fa-star" style="color: #ffd700;"></i> Featured Jobs</h2>
                <p class="text-muted">Latest opportunities from top companies</p>
            </div>

            <% if (jobs && jobs.length> 0) { %>
                <% jobs.forEach(job=> { %>
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card job-card h-100 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h5 class="card-title">
                                            <i class="fa fa-briefcase" style="color: #1e88a0;"></i>
                                            <%= job.title %>
                                        </h5>
                                        <h6 class="card-subtitle text-muted">
                                            <i class="fa fa-building"></i>
                                            <%= job.company || 'Company Name' %>
                                        </h6>
                                    </div>
                                    <span class="badge" style="background: #1e88a0;">
                                        <i class="fa fa-map-marker"></i>
                                        <%= job.location || 'Remote' %>
                                    </span>
                                </div>
                                <p class="card-text">
                                    <%= job.description ? job.description.substring(0, 100) + '...'
                                        : 'No description available.' %>
                                </p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span>
                                        <i class="fa fa-usd" style="color: #1e88a0;"></i>
                                        <%= job.salary || 'Negotiable' %>
                                    </span>
                                    <a href="/job/<%= job._id %>" class="btn btn-gradient btn-sm">
                                        <i class="fa fa-eye"></i> View Details
                                    </a>
                                </div>
                                <div class="mt-2">
                                    <span class="job-tag">
                                        <i class="fa fa-clock-o"></i>
                                        <%= job.type || 'Full-time' %>
                                    </span>
                                    <span class="job-tag">
                                        <i class="fa fa-graduation-cap"></i>
                                        <%= job.experience || 'Any Level' %>
                                    </span>
                                    <% if (job.skills && job.skills.length> 0) { %>
                                        <span class="job-tag">
                                            <i class="fa fa-code"></i>
                                            <%= job.skills.length %> skills
                                        </span>
                                        <% } %>
                                </div>
                                <div class="mt-2 text-muted small">
                                    <i class="fa fa-calendar"></i>
                                    Posted: <%= job.createdAt ? new Date(job.createdAt).toLocaleDateString('en-US', {
                                        month: 'short' , day: 'numeric' , year: 'numeric' }) : 'Recently' %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="col-12">
                                <div class="empty-state">
                                    <i class="fa fa-briefcase"></i>
                                    <h5>No jobs available right now</h5>
                                    <p class="text-muted">Check back later for new opportunities.</p>
                                    <a href="/jobs" class="btn btn-gradient">
                                        <i class="fa fa-search"></i> Browse All Jobs
                                    </a>
                                </div>
                            </div>
                            <% } %>
        </div>

        <!-- View All Jobs Button -->
        <div class="text-center mb-5">
            <a href="/jobs" class="btn btn-gradient btn-lg">
                <i class="fa fa-search"></i> View All Jobs
            </a>
        </div>

        <!-- Why JobHub Section -->
        <div class="features-section">
            <div class="row">
                <div class="col-12 text-center mb-4">
                    <h2><i class="fa fa-thumbs-up" style="color: #1e88a0;"></i> Why JobHub?</h2>
                    <p class="text-muted">We make job searching easier and faster</p>
                </div>
                <div class="col-md-4 text-center feature-box">
                    <i class="fa fa-bolt feature-icon"></i>
                    <h5>Fast & Easy Apply</h5>
                    <p>Submit applications in under 2 minutes with auto-fill profiles.</p>
                </div>
                <div class="col-md-4 text-center feature-box">
                    <i class="fa fa-shield feature-icon"></i>
                    <h5>Trusted Companies</h5>
                    <p>Verified employers and secure job postings.</p>
                </div>
                <div class="col-md-4 text-center feature-box">
                    <i class="fa fa-bell feature-icon"></i>
                    <h5>Smart Alerts</h5>
                    <p>Get notified when your dream job appears.</p>
                </div>
            </div>
        </div>

        <!-- Testimonials Section -->
        <div class="row mb-5">
            <div class="col-12 text-center mb-4">
                <h2><i class="fa fa-comments" style="color: #1e88a0;"></i> What Our Users Say</h2>
                <p class="text-muted">Success stories from job seekers</p>
            </div>
            <div class="col-md-4 mb-3">
                <div class="testimonial-card">
                    <i class="fa fa-quote-left fa-2x" style="color: #1e88a0; opacity: 0.3;"></i>
                    <p class="mt-2">"JobHub helped me find my dream job at Google! The platform is incredibly easy to
                        use."</p>
                    <div class="mt-3">
                        <i class="fa fa-user-circle fa-2x" style="color: #1e88a0;"></i>
                        <strong class="ms-2">Sarah Johnson</strong>
                        <div><small class="text-muted">Software Engineer</small></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="testimonial-card">
                    <i class="fa fa-quote-left fa-2x" style="color: #1e88a0; opacity: 0.3;"></i>
                    <p class="mt-2">"I got multiple interview calls within a week of posting my resume. Highly
                        recommended!"</p>
                    <div class="mt-3">
                        <i class="fa fa-user-circle fa-2x" style="color: #1e88a0;"></i>
                        <strong class="ms-2">Michael Chen</strong>
                        <div><small class="text-muted">Data Analyst</small></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="testimonial-card">
                    <i class="fa fa-quote-left fa-2x" style="color: #1e88a0; opacity: 0.3;"></i>
                    <p class="mt-2">"The best job portal I've ever used. Clean interface and relevant job matches."</p>
                    <div class="mt-3">
                        <i class="fa fa-user-circle fa-2x" style="color: #1e88a0;"></i>
                        <strong class="ms-2">Emily Rodriguez</strong>
                        <div><small class="text-muted">Product Manager</small></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="card cta-card text-white mb-5">
            <div class="card-body p-5 text-center">
                <i class="fa fa-users fa-3x mb-3"></i>
                <h2>Ready to take the next step?</h2>
                <p class="lead">Create an account and start your journey today.</p>
                <a href="/register" class="btn btn-light btn-lg mt-2 me-2">
                    <i class="fa fa-user-plus"></i> Sign Up Free
                </a>
                <a href="/login" class="btn btn-outline-light btn-lg mt-2">
                    <i class="fa fa-sign-in"></i> Login
                </a>
            </div>
        </div>
    </div>

    <script>
        // Counter animation for statistics
        const counters = document.querySelectorAll('.counter');
        const speed = 200;

        const animateCounter = (counter) => {
            const target = parseInt(counter.getAttribute('data-target'));
            let count = 0;
            const increment = target / speed;

            const updateCount = () => {
                if (count < target) {
                    count += increment;
                    counter.innerText = Math.ceil(count);
                    setTimeout(updateCount, 20);
                } else {
                    counter.innerText = target;
                }
            };

            updateCount();
        };

        // Intersection Observer for counter animation
        const observerOptions = {
            threshold: 0.5,
            rootMargin: "0px"
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target;
                    animateCounter(counter);
                    observer.unobserve(counter);
                }
            });
        }, observerOptions);

        counters.forEach(counter => {
            observer.observe(counter);
        });
    </script>

    <%- include('includes/footer') %>