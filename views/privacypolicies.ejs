<!-- views/privacy.ejs -->
<%- include('includes/header', { title: 'Privacy Policy - JobHub' , currentPage: 'privacy' }) %>

    <style>
        .privacy-hero {
            background: linear-gradient(135deg, #0b3d3f 0%, #1a5f5c 25%, #1e88a0 50%, #2c9ba8 75%, #3aa8c5 100%);
            padding: 60px 0 80px;
            position: relative;
            overflow: hidden;
        }

        .privacy-hero::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: floatPrivacy 8s ease-in-out infinite;
        }

        .privacy-hero::after {
            content: '';
            position: absolute;
            bottom: -20%;
            left: -5%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            animation: floatPrivacy 6s ease-in-out infinite reverse;
        }

        @keyframes floatPrivacy {

            0%,
            100% {
                transform: translate(0, 0) rotate(0deg);
            }

            50% {
                transform: translate(30px, -30px) rotate(10deg);
            }
        }

        .privacy-container {
            background: white;
            border-radius: 1.5rem;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
            padding: 3rem;
            margin-top: -40px;
            position: relative;
            z-index: 1;
        }

        .privacy-section {
            margin-bottom: 2.5rem;
        }

        .privacy-section:last-child {
            margin-bottom: 0;
        }

        .privacy-section h3 {
            color: #0b3d3f;
            font-weight: 700;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .privacy-section h3 .section-number {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            color: white;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            font-size: 0.9rem;
            font-weight: 600;
            flex-shrink: 0;
        }

        .privacy-section h4 {
            color: #1a5f5c;
            font-weight: 600;
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
        }

        .privacy-section p {
            color: #4a5568;
            line-height: 1.8;
            margin-bottom: 1rem;
        }

        .privacy-section ul,
        .privacy-section ol {
            color: #4a5568;
            line-height: 1.8;
            padding-left: 1.5rem;
            margin-bottom: 1rem;
        }

        .privacy-section ul li,
        .privacy-section ol li {
            margin-bottom: 0.5rem;
        }

        .privacy-section ul li::marker {
            color: #1e88a0;
        }

        .privacy-highlight {
            background: #f0f7fa;
            border-left: 4px solid #1e88a0;
            padding: 1.5rem 2rem;
            border-radius: 0.5rem;
            margin: 1.5rem 0;
        }

        .privacy-highlight h5 {
            color: #0b3d3f;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .privacy-highlight p {
            margin-bottom: 0;
        }

        .privacy-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.3rem 0.8rem;
            background: rgba(30, 136, 160, 0.1);
            color: #1e88a0;
            border-radius: 2rem;
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
            margin-right: 0.5rem;
        }

        .privacy-badge i {
            margin-right: 0.3rem;
        }

        .privacy-table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.5rem 0;
            border-radius: 0.5rem;
            overflow: hidden;
        }

        .privacy-table thead {
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            color: white;
        }

        .privacy-table th {
            padding: 12px 16px;
            text-align: left;
            font-weight: 600;
        }

        .privacy-table td {
            padding: 12px 16px;
            border-bottom: 1px solid #e9ecef;
        }

        .privacy-table tbody tr:hover {
            background: #f8f9fa;
        }

        .privacy-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin: 1.5rem 0;
        }

        .privacy-grid-item {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 0.75rem;
            transition: all 0.3s ease;
        }

        .privacy-grid-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .privacy-grid-item i {
            font-size: 2rem;
            color: #1e88a0;
            margin-bottom: 0.75rem;
        }

        .privacy-grid-item h6 {
            color: #0b3d3f;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .privacy-grid-item p {
            font-size: 0.9rem;
            margin-bottom: 0;
        }

        .privacy-toc {
            background: #f8f9fa;
            border-radius: 0.75rem;
            padding: 1.25rem;
            margin-bottom: 2rem;
        }

        .privacy-toc ul {
            columns: 2;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .privacy-toc ul li {
            padding: 0.25rem 0;
        }

        .privacy-toc ul li a {
            color: #1e88a0;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .privacy-toc ul li a:hover {
            color: #0b3d3f;
            text-decoration: underline;
        }

        .cookie-banner {
            background: linear-gradient(135deg, #e0f2f1, #b2dfdb);
            border-radius: 1rem;
            padding: 2rem;
            margin-top: 2rem;
            text-align: center;
        }

        .cookie-banner h4 {
            color: #0b3d3f;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .cookie-banner p {
            color: #2d3748;
            margin-bottom: 1rem;
        }

        .cookie-banner .btn-cookie {
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            border: none;
            border-radius: 2rem;
            padding: 10px 30px;
            color: white;
            font-weight: 600;
            transition: all 0.3s ease;
            display: inline-block;
            text-decoration: none;
            margin: 0 0.5rem;
            cursor: pointer;
        }

        .cookie-banner .btn-cookie:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(30, 136, 160, 0.4);
            color: white;
        }

        .cookie-banner .btn-cookie-outline {
            background: transparent;
            border: 2px solid #1e88a0;
            border-radius: 2rem;
            padding: 10px 30px;
            color: #1e88a0;
            font-weight: 600;
            transition: all 0.3s ease;
            display: inline-block;
            text-decoration: none;
            margin: 0 0.5rem;
            cursor: pointer;
        }

        .cookie-banner .btn-cookie-outline:hover {
            background: #1e88a0;
            color: white;
        }

        @media (max-width: 768px) {
            .privacy-container {
                padding: 1.5rem;
                margin-top: -20px;
            }

            .privacy-section h3 {
                font-size: 1.25rem;
            }

            .privacy-highlight {
                padding: 1rem;
            }

            .privacy-grid {
                grid-template-columns: 1fr;
            }

            .privacy-toc ul {
                columns: 1;
            }

            .cookie-banner {
                padding: 1.25rem;
            }

            .cookie-banner .btn-cookie,
            .cookie-banner .btn-cookie-outline {
                display: block;
                margin: 0.5rem 0;
            }
        }

        @media (max-width: 576px) {
            .privacy-container {
                padding: 1rem;
            }

            .privacy-section {
                margin-bottom: 1.5rem;
            }

            .privacy-highlight {
                padding: 0.75rem;
            }

            .privacy-table {
                font-size: 0.85rem;
            }

            .privacy-table th,
            .privacy-table td {
                padding: 8px 10px;
            }
        }
    </style>

    <!-- Privacy Hero Section -->
    <section class="privacy-hero">
        <div class="container text-center position-relative" style="z-index: 1;">
            <i class="fa fa-shield fa-4x mb-4" style="animation: fadeInUp 0.6s ease;"></i>
            <h1 class="display-4 fw-bold text-white" style="animation: fadeInUp 0.6s ease 0.1s backwards;">
                Privacy Policy
            </h1>
            <p class="lead text-white-50" style="animation: fadeInUp 0.6s ease 0.2s backwards;">
                Your privacy matters to us. Learn how we protect your data.
            </p>
            <p class="text-white-50 small" style="animation: fadeInUp 0.6s ease 0.3s backwards;">
                Last Updated: <span id="lastUpdated">
                    <%= new Date().toLocaleDateString('en-US', { year: 'numeric' , month: 'long' , day: 'numeric' }) %>
                </span>
            </p>
        </div>
    </section>

    <div class="container">
        <div class="privacy-container">
            <!-- Quick Summary -->
            <div class="privacy-highlight mb-4">
                <h5><i class="fa fa-info-circle text-primary me-2"></i>Our Commitment to Privacy</h5>
                <p>
                    At JobHub, we take your privacy seriously. This Privacy Policy explains how we collect, use,
                    disclose, and safeguard your personal information when you use our platform. We are committed
                    to protecting your data and being transparent about our practices.
                </p>
                <div class="mt-3">
                    <span class="privacy-badge"><i class="fa fa-check-circle"></i> GDPR Compliant</span>
                    <span class="privacy-badge"><i class="fa fa-check-circle"></i> CCPA Compliant</span>
                    <span class="privacy-badge"><i class="fa fa-check-circle"></i> Data Encrypted</span>
                </div>
            </div>

            <!-- Table of Contents -->
            <div class="privacy-toc">
                <h6 class="fw-bold mb-2"><i class="fa fa-list-ul text-primary me-2"></i>Quick Navigation</h6>
                <ul>
                    <li><a href="#section-1">1. Information We Collect</a></li>
                    <li><a href="#section-2">2. How We Use Your Information</a></li>
                    <li><a href="#section-3">3. Information Sharing</a></li>
                    <li><a href="#section-4">4. Data Security</a></li>
                    <li><a href="#section-5">5. Your Rights</a></li>
                    <li><a href="#section-6">6. Cookies & Tracking</a></li>
                    <li><a href="#section-7">7. Contact Us</a></li>
                </ul>
            </div>

            <!-- Section 1 -->
            <div id="section-1" class="privacy-section">
                <h3>
                    <span class="section-number">1</span>
                    Information We Collect
                </h3>
                <p>
                    We collect various types of information to provide and improve our services:
                </p>

                <h4>1.1 Personal Information</h4>
                <p>When you create an account or apply for a job, we collect:</p>
                <ul>
                    <li><strong>Full Name</strong> - For identification and communication</li>
                    <li><strong>Email Address</strong> - For account management and notifications</li>
                    <li><strong>Phone Number</strong> - For contact purposes</li>
                    <li><strong>Resume/CV</strong> - For job applications</li>
                    <li><strong>Cover Letter</strong> - For job applications</li>
                    <li><strong>Skills & Experience</strong> - For matching with job opportunities</li>
                </ul>

                <h4>1.2 Employer Information</h4>
                <p>For employers posting jobs, we collect:</p>
                <ul>
                    <li><strong>Company Name</strong> - For job postings</li>
                    <li><strong>Company Website</strong> - For verification</li>
                    <li><strong>Industry</strong> - For job categorization</li>
                    <li><strong>Job Postings</strong> - Job descriptions and requirements</li>
                </ul>

                <h4>1.3 Technical Data</h4>
                <p>We automatically collect technical information:</p>
                <ul>
                    <li><strong>IP Address</strong> - For security and analytics</li>
                    <li><strong>Browser Type</strong> - For compatibility</li>
                    <li><strong>Device Information</strong> - For optimization</li>
                    <li><strong>Usage Data</strong> - For platform improvement</li>
                    <li><strong>Cookies</strong> - For user experience</li>
                </ul>

                <div class="privacy-grid">
                    <div class="privacy-grid-item">
                        <i class="fa fa-user"></i>
                        <h6>Personal Data</h6>
                        <p>Name, email, phone, resume, and profile information</p>
                    </div>
                    <div class="privacy-grid-item">
                        <i class="fa fa-building"></i>
                        <h6>Company Data</h6>
                        <p>Company name, website, industry, and job postings</p>
                    </div>
                    <div class="privacy-grid-item">
                        <i class="fa fa-server"></i>
                        <h6>Technical Data</h6>
                        <p>IP address, browser type, device info, and cookies</p>
                    </div>
                </div>
            </div>

            <!-- Section 2 -->
            <div id="section-2" class="privacy-section">
                <h3>
                    <span class="section-number">2</span>
                    How We Use Your Information
                </h3>
                <p>
                    We use your information for the following purposes:
                </p>
                <ul>
                    <li><strong>Account Management:</strong> To create and manage your account</li>
                    <li><strong>Job Matching:</strong> To match job seekers with suitable positions</li>
                    <li><strong>Job Applications:</strong> To process and submit your applications</li>
                    <li><strong>Communications:</strong> To send notifications, updates, and promotional materials</li>
                    <li><strong>Analytics:</strong> To improve our platform and user experience</li>
                    <li><strong>Security:</strong> To protect against fraud and unauthorized access</li>
                </ul>
                <div class="privacy-highlight">
                    <h5><i class="fa fa-gavel text-primary me-2"></i>Legal Basis</h5>
                    <p>
                        We process your data based on:
                    </p>
                    <ul class="mb-0">
                        <li><strong>Consent:</strong> You have given us explicit consent to process your data</li>
                        <li><strong>Contract:</strong> Processing is necessary for the performance of our services</li>
                        <li><strong>Legal Obligation:</strong> Processing is required by law</li>
                        <li><strong>Legitimate Interest:</strong> Processing is necessary for our legitimate business
                            interests</li>
                    </ul>
                </div>
            </div>

            <!-- Section 3 -->
            <div id="section-3" class="privacy-section">
                <h3>
                    <span class="section-number">3</span>
                    Information Sharing
                </h3>
                <p>
                    We may share your information in the following circumstances:
                </p>

                <h4>3.1 With Employers</h4>
                <p>
                    When you apply for a job, your application information (name, email, resume, cover letter)
                    is shared with the employer to process your application.
                </p>

                <h4>3.2 With Service Providers</h4>
                <p>
                    We may share data with trusted third-party service providers who assist us in operating the
                    platform, such as hosting, email delivery, and analytics services.
                </p>

                <h4>3.3 Legal Requirements</h4>
                <p>
                    We may disclose your information if required by law, court order, or government regulation.
                </p>

                <table class="privacy-table">
                    <thead>
                        <tr>
                            <th>Recipient</th>
                            <th>Purpose</th>
                            <th>Data Shared</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Employers</td>
                            <td>Job applications</td>
                            <td>Resume, contact info, cover letter</td>
                        </tr>
                        <tr>
                            <td>Hosting Providers</td>
                            <td>Platform hosting</td>
                            <td>All platform data</td>
                        </tr>
                        <tr>
                            <td>Analytics Services</td>
                            <td>Platform improvement</td>
                            <td>Usage data (anonymized)</td>
                        </tr>
                        <tr>
                            <td>Legal Authorities</td>
                            <td>Compliance</td>
                            <td>As required by law</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Section 4 -->
            <div id="section-4" class="privacy-section">
                <h3>
                    <span class="section-number">4</span>
                    Data Security
                </h3>
                <p>
                    We implement robust security measures to protect your data:
                </p>
                <ul>
                    <li><strong>Encryption:</strong> All data is encrypted in transit using SSL/TLS</li>
                    <li><strong>Access Control:</strong> Strict access controls to personal data</li>
                    <li><strong>Regular Audits:</strong> Regular security audits and penetration testing</li>
                    <li><strong>Data Minimization:</strong> We only collect data that is necessary</li>
                    <li><strong>Secure Storage:</strong> Data is stored on secure, encrypted servers</li>
                </ul>
                <div class="privacy-highlight">
                    <h5><i class="fa fa-lock text-primary me-2"></i>Data Retention</h5>
                    <p>
                        We retain your personal data only for as long as necessary to fulfill the purposes
                        outlined in this policy. When you delete your account, all your data is permanently
                        removed from our systems.
                    </p>
                </div>
            </div>

            <!-- Section 5 -->
            <div id="section-5" class="privacy-section">
                <h3>
                    <span class="section-number">5</span>
                    Your Rights
                </h3>
                <p>
                    You have the following rights regarding your personal data:
                </p>
                <ul>
                    <li><strong>Right to Access:</strong> Request a copy of your personal data</li>
                    <li><strong>Right to Rectification:</strong> Correct inaccurate or incomplete data</li>
                    <li><strong>Right to Erasure:</strong> Request deletion of your personal data ("right to be
                        forgotten")</li>
                    <li><strong>Right to Restriction:</strong> Restrict processing of your data</li>
                    <li><strong>Right to Data Portability:</strong> Receive your data in a machine-readable format</li>
                    <li><strong>Right to Object:</strong> Object to processing of your data</li>
                    <li><strong>Right to Withdraw Consent:</strong> Withdraw consent at any time</li>
                </ul>
                <p>
                    To exercise any of these rights, please contact us at <a href="mailto:privacy@jobhub.com"
                        class="text-decoration-none">privacy@jobhub.com</a>.
                </p>
            </div>

            <!-- Section 6 -->
            <div id="section-6" class="privacy-section">
                <h3>
                    <span class="section-number">6</span>
                    Cookies and Tracking
                </h3>
                <p>
                    We use cookies and similar tracking technologies to enhance your experience:
                </p>
                <ul>
                    <li><strong>Essential Cookies:</strong> Required for basic platform functionality</li>
                    <li><strong>Performance Cookies:</strong> Used to improve platform performance</li>
                    <li><strong>Analytics Cookies:</strong> Used to analyze user behavior and improve the platform</li>
                    <li><strong>Preference Cookies:</strong> Remember your preferences and settings</li>
                </ul>
                <p>
                    You can control cookie preferences through your browser settings. However, disabling
                    some cookies may affect platform functionality.
                </p>
            </div>

            <!-- Section 7 -->
            <div id="section-7" class="privacy-section">
                <h3>
                    <span class="section-number">7</span>
                    Contact Us
                </h3>
                <p>
                    If you have any questions, concerns, or requests regarding this Privacy Policy, please contact us:
                </p>
                <ul>
                    <li><i class="fa fa-envelope text-primary me-2"></i>Email: <a href="mailto:privacy@jobhub.com"
                            class="text-decoration-none">privacy@jobhub.com</a></li>
                    <li><i class="fa fa-phone text-primary me-2"></i>Phone: +1 (555) 123-4567</li>
                    <li><i class="fa fa-map-marker text-primary me-2"></i>Address: 123 Job Street, Employment City, EC
                        12345</li>
                    <li><i class="fa fa-clock-o text-primary me-2"></i>Response Time: Within 48 hours</li>
                </ul>
            </div>

            <!-- Cookie Banner -->
            <div class="cookie-banner">
                <i class="fa fa-cookie-bite fa-3x text-primary mb-3"></i>
                <h4>Cookie Preferences</h4>
                <p>
                    We use cookies to enhance your experience, analyze site usage, and deliver personalized content.
                    By clicking "Accept All", you consent to our use of cookies.
                </p>
                <div>
                    <button class="btn-cookie" onclick="acceptCookies()">
                        <i class="fa fa-check me-2"></i>Accept All
                    </button>
                    <button class="btn-cookie-outline" onclick="rejectCookies()">
                        <i class="fa fa-times me-2"></i>Reject Non-Essential
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function acceptCookies() {
            document.cookie = "cookies_accepted=true; max-age=31536000; path=/";
            alert('Cookies accepted! Your preferences have been saved.');
            location.reload();
        }

        function rejectCookies() {
            document.cookie = "cookies_accepted=false; max-age=31536000; path=/";
            alert('Only essential cookies will be used.');
            location.reload();
        }

        function checkCookieConsent() {
            const cookies = document.cookie.split(';');
            for (let cookie of cookies) {
                const [name, value] = cookie.trim().split('=');
                if (name === 'cookies_accepted' && value === 'true') {
                    const banner = document.querySelector('.cookie-banner');
                    if (banner) {
                        banner.style.display = 'none';
                    }
                    return true;
                }
            }
            return false;
        }

        document.addEventListener('DOMContentLoaded', function () {
            checkCookieConsent();
        });
    </script>

    <%- include('includes/footer') %>