<%- include('includes/header', { title: 'JobHub - Create Account' , currentPage: 'register' }) %>

    <style>
        /* Register Page Specific Styles */
        .register-hero {
            background: linear-gradient(135deg, #0b3d3f 0%, #1a5f5c 25%, #1e88a0 50%, #2c9ba8 75%, #3aa8c5 100%);
            padding: 60px 0;
            position: relative;
            overflow: hidden;
        }

        .register-hero::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: floatRegister 8s ease-in-out infinite;
        }

        .register-hero::after {
            content: '';
            position: absolute;
            bottom: -20%;
            left: -5%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            animation: floatRegister 6s ease-in-out infinite reverse;
        }

        @keyframes floatRegister {

            0%,
            100% {
                transform: translate(0, 0) rotate(0deg);
            }

            50% {
                transform: translate(30px, -30px) rotate(10deg);
            }
        }

        .register-card {
            background: white;
            border-radius: 1.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        .register-card:hover {
            transform: translateY(-5px);
        }

        .register-header {
            background: linear-gradient(135deg, #1e88a0, #3aa8c5);
            padding: 2rem;
            text-align: center;
            color: white;
        }

        .register-body {
            padding: 2rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            font-weight: 500;
            color: #0b3d3f;
            margin-bottom: 0.5rem;
        }

        .form-label i {
            color: #1e88a0;
            margin-right: 0.5rem;
        }

        .input-group-custom {
            position: relative;
        }

        .input-group-custom .form-control {
            border: 1px solid #e0e0e0;
            border-radius: 0.5rem;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .input-group-custom .form-control:focus {
            border-color: #1e88a0;
            box-shadow: 0 0 0 0.2rem rgba(30, 136, 160, 0.1);
            outline: none;
        }

        .btn-register {
            background: linear-gradient(135deg, #1e88a0, #2c9ba8);
            border: none;
            border-radius: 0.5rem;
            padding: 12px;
            color: white;
            font-weight: 500;
            transition: all 0.3s ease;
            width: 100%;
        }

        .btn-register:hover {
            background: linear-gradient(135deg, #2c9ba8, #3aa8c5);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(30, 136, 160, 0.4);
        }

        .login-link {
            color: #1e88a0;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .login-link:hover {
            color: #0b3d3f;
            text-decoration: underline;
        }

        .alert-error {
            background: #fee;
            border-left: 4px solid #dc3545;
            color: #dc3545;
            padding: 0.75rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }

        .alert-success {
            background: #e0f2f1;
            border-left: 4px solid #1e88a0;
            color: #0b3d3f;
            padding: 0.75rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }

        .terms-checkbox {
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .terms-checkbox input {
            margin-top: 0.2rem;
        }

        .terms-text {
            font-size: 0.85rem;
            color: #666;
        }

        .terms-text a {
            color: #1e88a0;
            text-decoration: none;
        }

        .terms-text a:hover {
            text-decoration: underline;
        }

        .feature-item {
            display: flex;
            align-items: center;
            margin-bottom: 1rem;
        }

        .feature-icon-small {
            width: 35px;
            height: 35px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            color: white;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .company-field {
            transition: all 0.3s ease;
        }
    </style>

    <!-- Register Hero Section -->
    <section class="register-hero">
        <div class="container text-center position-relative" style="z-index: 1;">
            <i class="fa fa-user-plus fa-4x mb-4" style="animation: fadeInUp 0.6s ease;"></i>
            <h1 class="display-4 fw-bold" style="animation: fadeInUp 0.6s ease 0.1s backwards;">Create an Account</h1>
            <p class="lead" style="animation: fadeInUp 0.6s ease 0.2s backwards;">Join JobHub and start your career
                journey today</p>
        </div>
    </section>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="row g-0">
                    <!-- Registration Form Side -->
                    <div class="col-md-6">
                        <div class="register-card">
                            <div class="register-header">
                                <i class="fa fa-user-circle fa-2x mb-2"></i>
                                <h3 class="mb-0">Sign Up</h3>
                                <p class="mb-0 opacity-75">It's free and takes only 2 minutes</p>
                            </div>
                            <div class="register-body">
                                <!-- Error Message Display -->
                                <% if (locals.error) { %>
                                    <div class="alert-error">
                                        <i class="fa fa-exclamation-triangle"></i>
                                        <%= error %>
                                    </div>
                                    <% } %>

                                        <!-- Success Message Display -->
                                        <% if (locals.success) { %>
                                            <div class="alert-success">
                                                <i class="fa fa-check-circle"></i>
                                                <%= success %>
                                            </div>
                                            <% } %>

                                                <!-- Simple Registration Form - POST to /register -->
                                                <form id="registerForm" action="/register" method="post">
                                                    <!-- Email -->
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-envelope"></i> Email
                                                            Address *</label>
                                                        <div class="input-group-custom">
                                                            <input type="email" class="form-control" name="email"
                                                                placeholder="your@email.com"
                                                                value="<%= locals.formData && formData.email ? formData.email : '' %>"
                                                                required>
                                                        </div>
                                                    </div>

                                                    <!-- Password -->
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-lock"></i> Password
                                                            *</label>
                                                        <div class="input-group-custom">
                                                            <input type="password" class="form-control" name="password"
                                                                placeholder="Create a password (min. 6 characters)"
                                                                required>
                                                        </div>
                                                    </div>

                                                    <!-- Confirm Password -->
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-lock"></i> Confirm
                                                            Password *</label>
                                                        <div class="input-group-custom">
                                                            <input type="password" class="form-control"
                                                                name="confirmPassword"
                                                                placeholder="Confirm your password" required>
                                                        </div>
                                                    </div>

                                                    <!-- Full Name -->
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-user"></i> Full Name
                                                            *</label>
                                                        <div class="input-group-custom">
                                                            <input type="text" class="form-control" name="fullname"
                                                                placeholder="John Doe"
                                                                value="<%= locals.formData && formData.fullname ? formData.fullname : '' %>"
                                                                required>
                                                        </div>
                                                    </div>

                                                    <!-- Phone Number -->
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-phone"></i> Phone
                                                            Number</label>
                                                        <div class="input-group-custom">
                                                            <input type="tel" class="form-control" name="phone"
                                                                placeholder="+1 234 567 8900"
                                                                value="<%= locals.formData && formData.phone ? formData.phone : '' %>">
                                                        </div>
                                                    </div>

                                                    <!-- Account Type -->
                                                    <div class="form-group">
                                                        <label class="form-label"><i class="fa fa-briefcase"></i>
                                                            Account Type *</label>
                                                        <div class="row">
                                                            <div class="col-6">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio"
                                                                        name="accountType" id="jobSeeker"
                                                                        value="jobseeker" <%=(locals.formData &&
                                                                        formData.accountType==='jobseeker' ) ||
                                                                        !locals.formData ? 'checked' : '' %>>
                                                                    <label class="form-check-label" for="jobSeeker">
                                                                        <i class="fa fa-user"></i> Job Seeker
                                                                    </label>
                                                                </div>
                                                            </div>
                                                            <div class="col-6">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="radio"
                                                                        name="accountType" id="employer"
                                                                        value="employer" <%=locals.formData &&
                                                                        formData.accountType==='employer' ? 'checked'
                                                                        : '' %>>
                                                                    <label class="form-check-label" for="employer">
                                                                        <i class="fa fa-building"></i> Employer
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Company Name (hidden by default, shows when employer selected) -->
                                                    <div class="form-group company-field" id="companyField"
                                                        style="display: none;">
                                                        <label class="form-label"><i class="fa fa-building"></i> Company
                                                            Name</label>
                                                        <div class="input-group-custom">
                                                            <input type="text" class="form-control" name="company"
                                                                placeholder="Your company name"
                                                                value="<%= locals.formData && formData.company ? formData.company : '' %>">
                                                        </div>
                                                    </div>

                                                    <!-- Terms & Conditions -->
                                                    <div class="terms-checkbox mb-3">
                                                        <input type="checkbox" name="termsAccepted" id="termsAccepted"
                                                            required <%=locals.formData && formData.termsAccepted
                                                            ? 'checked' : '' %>>
                                                        <label for="termsAccepted" class="terms-text">
                                                            I agree to the <a href="#">Terms of Service</a> and <a
                                                                href="#">Privacy Policy</a> *
                                                        </label>
                                                    </div>

                                                    <!-- Newsletter Opt-in -->
                                                    <div class="terms-checkbox mb-4">
                                                        <input type="checkbox" name="newsletterOptIn"
                                                            id="newsletterOptIn" <%=locals.formData &&
                                                            formData.newsletterOptIn ? 'checked' : '' %>>
                                                        <label for="newsletterOptIn" class="terms-text">
                                                            I want to receive job alerts and career tips via email
                                                        </label>
                                                    </div>

                                                    <!-- Info Note -->
                                                    <div class="alert-info"
                                                        style="background: #e3f2fd; padding: 0.75rem; border-radius: 0.5rem; border-left: 4px solid #1e88a0; margin-bottom: 1.5rem;">
                                                        <i class="fa fa-info-circle"></i>
                                                        <small>By creating an account, you'll get access to thousands of
                                                            job opportunities, personalized recommendations, and
                                                            more!</small>
                                                    </div>

                                                    <!-- Submit Button -->
                                                    <button type="submit" class="btn-register">
                                                        <i class="fa fa-user-plus"></i> Create Account
                                                    </button>

                                                    <hr class="my-4">

                                                    <div class="text-center">
                                                        <p class="mb-0">Already have an account? <a href="/login"
                                                                class="login-link"><i class="fa fa-sign-in"></i> Login
                                                                here</a></p>
                                                    </div>
                                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Benefits Side -->
                    <div class="col-md-6"
                        style="background: linear-gradient(135deg, #0b3d3f, #1e88a0); border-radius: 1rem; padding: 2rem; color: white;">
                        <div class="h-100 d-flex flex-column justify-content-center">
                            <i class="fa fa-gift fa-3x mb-3"></i>
                            <h3 class="mb-4">Why Join JobHub?</h3>

                            <div class="feature-item">
                                <div class="feature-icon-small">
                                    <i class="fa fa-search"></i>
                                </div>
                                <div>
                                    <strong>Access to 5000+ jobs</strong>
                                    <p class="small mb-0 opacity-75">Browse thousands of opportunities</p>
                                </div>
                            </div>

                            <div class="feature-item">
                                <div class="feature-icon-small">
                                    <i class="fa fa-bell"></i>
                                </div>
                                <div>
                                    <strong>Free Job Alerts</strong>
                                    <p class="small mb-0 opacity-75">Get notified about matching jobs</p>
                                </div>
                            </div>

                            <div class="feature-item">
                                <div class="feature-icon-small">
                                    <i class="fa fa-file-text"></i>
                                </div>
                                <div>
                                    <strong>Save & Track Applications</strong>
                                    <p class="small mb-0 opacity-75">Manage your job applications</p>
                                </div>
                            </div>

                            <div class="feature-item">
                                <div class="feature-icon-small">
                                    <i class="fa fa-star"></i>
                                </div>
                                <div>
                                    <strong>Personalized Recommendations</strong>
                                    <p class="small mb-0 opacity-75">AI-powered job matching</p>
                                </div>
                            </div>

                            <div class="feature-item">
                                <div class="feature-icon-small">
                                    <i class="fa fa-resume"></i>
                                </div>
                                <div>
                                    <strong>Professional Resume Builder</strong>
                                    <p class="small mb-0 opacity-75">Create standout resumes easily</p>
                                </div>
                            </div>

                            <div class="mt-4 pt-3">
                                <div class="d-flex">
                                    <i class="fa fa-quote-left fa-2x opacity-50 me-2"></i>
                                    <p class="small fst-italic mb-0">"I found my dream job within a week of joining
                                        JobHub!"</p>
                                </div>
                                <div class="mt-2">
                                    <i class="fa fa-user-circle"></i>
                                    <small> - Michael Chen, Software Developer</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Simple JavaScript only for UX improvements (no form submission override)

        // Show/hide company field based on account type selection
        const employerRadio = document.getElementById('employer');
        const jobSeekerRadio = document.getElementById('jobSeeker');
        const companyField = document.getElementById('companyField');

        function toggleCompanyField() {
            if (employerRadio.checked) {
                companyField.style.display = 'block';
            } else {
                companyField.style.display = 'none';
            }
        }

        if (employerRadio && jobSeekerRadio) {
            employerRadio.addEventListener('change', toggleCompanyField);
            jobSeekerRadio.addEventListener('change', toggleCompanyField);
            toggleCompanyField(); // initial call
        }

        // Basic client-side validation for better UX (doesn't prevent form submission)
        const form = document.getElementById('registerForm');

        if (form) {
            form.addEventListener('submit', function (event) {
                const password = document.querySelector('[name="password"]').value;
                const confirmPassword = document.querySelector('[name="confirmPassword"]').value;
                const termsAccepted = document.getElementById('termsAccepted');

                if (password !== confirmPassword) {
                    event.preventDefault();
                    alert('Passwords do not match. Please try again.');
                    return false;
                }

                if (password.length < 6) {
                    event.preventDefault();
                    alert('Password must be at least 6 characters long.');
                    return false;
                }

                if (!termsAccepted.checked) {
                    event.preventDefault();
                    alert('Please accept the Terms of Service and Privacy Policy.');
                    return false;
                }

                return true;
            });
        }
    </script>

    <%- include('includes/footer') %>